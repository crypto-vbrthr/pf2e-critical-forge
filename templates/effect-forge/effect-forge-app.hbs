<div class="effect-forge-shell">
  <div class="effect-forge-workspace">
    <main class="effect-forge-panel effect-forge-editor" data-preserve-scroll data-scroll-key="editor">
      {{#if externalMode}}
        <section class="effect-forge-section effect-forge-external-mode">
          <header class="effect-forge-section-header">
            <h2><i class="fa-solid fa-layer-group"></i> {{localize "PF2E_CRITICAL_FORGE.EffectForge.ExternalModeTitle"}}</h2>
            <span class="effect-forge-dirty-indicator {{#if isDirty}}dirty{{else}}clean{{/if}}" data-dirty-indicator>
              <i class="fa-solid {{#if isDirty}}fa-circle{{else}}fa-circle-check{{/if}}"></i>
              <span data-dirty-text>{{dirtyStatusText}}</span>
            </span>
          </header>
          <p>{{localize "PF2E_CRITICAL_FORGE.EffectForge.ExternalModeHint"}}</p>
        </section>
      {{else}}
      <section class="effect-forge-section effect-forge-item-workflow">
        <header class="effect-forge-section-header">
          <h2>{{localize "PF2E_CRITICAL_FORGE.EffectForge.ItemWorkflow"}}</h2>
          <div class="effect-forge-workflow-status">
            <span class="effect-forge-dirty-indicator {{#if isDirty}}dirty{{else}}clean{{/if}}" data-dirty-indicator>
              <i class="fa-solid {{#if isDirty}}fa-circle{{else}}fa-circle-check{{/if}}"></i>
              <span data-dirty-text>{{dirtyStatusText}}</span>
            </span>
            {{#if editingItem}}
              <span class="effect-forge-editing-badge">
                <i class="fa-solid fa-pen-to-square"></i>
                {{localize "PF2E_CRITICAL_FORGE.EffectForge.Editing"}}
              </span>
            {{else}}
              <span class="effect-forge-new-badge">
                <i class="fa-solid fa-file-circle-plus"></i>
                {{localize "PF2E_CRITICAL_FORGE.EffectForge.NewEffect"}}
              </span>
            {{/if}}
          </div>
        </header>

        <div class="effect-forge-load-row">
          <label class="effect-forge-field">
            <span>{{localize "PF2E_CRITICAL_FORGE.EffectForge.WorldEffect"}}</span>
            <select name="selectedItemId" {{#unless hasWorldEffects}}disabled{{/unless}}>
              <option value="">{{localize "PF2E_CRITICAL_FORGE.EffectForge.SelectWorldEffect"}}</option>
              {{#each worldEffectOptions as |option|}}
                <option value="{{option.value}}" {{#if option.selected}}selected{{/if}}>{{option.label}}</option>
              {{/each}}
            </select>
          </label>

          <button type="button" data-action="loadSelectedItem" {{#unless hasWorldEffects}}disabled{{/unless}}>
            <i class="fa-solid fa-folder-open"></i>
            {{localize "PF2E_CRITICAL_FORGE.EffectForge.LoadItem"}}
          </button>

          <button type="button" data-action="newEffect">
            <i class="fa-solid fa-file-circle-plus"></i>
            {{localize "PF2E_CRITICAL_FORGE.EffectForge.NewEffect"}}
          </button>
        </div>

        <div
          class="effect-forge-item-drop-zone"
          data-effect-drop-zone
          role="region"
          aria-label="{{localize 'PF2E_CRITICAL_FORGE.EffectForge.DropEffectHere'}}"
        >
          <i class="fa-solid fa-file-import"></i>
          <div>
            <strong>{{localize "PF2E_CRITICAL_FORGE.EffectForge.DropEffectHere"}}</strong>
            <small>{{localize "PF2E_CRITICAL_FORGE.EffectForge.DropEffectHint"}}</small>
          </div>
        </div>

        {{#if editingItem}}
          <div class="effect-forge-loaded-item">
            <i class="fa-solid fa-link"></i>
            <span>{{localize "PF2E_CRITICAL_FORGE.EffectForge.LoadedItem"}}: <strong>{{sourceItemName}}</strong></span>
          </div>
        {{/if}}

        {{#if hasItemReadWarnings}}
          <div class="effect-forge-preserved-rules-warning">
            <i class="fa-solid fa-triangle-exclamation"></i>
            <span>{{unmanagedRulesWarningText}}</span>
          </div>
        {{/if}}

        {{#if migrationReport.migrated}}
          <div class="effect-forge-migration-notice">
            <i class="fa-solid fa-code-branch"></i>
            <span>{{localize "PF2E_CRITICAL_FORGE.EffectForge.MigrationApplied"}} {{migrationReport.fromVersion}} → {{migrationReport.toVersion}}</span>
          </div>
        {{/if}}
      </section>

      <section class="effect-forge-section effect-forge-transfer-section">
        <header class="effect-forge-section-header">
          <h2>{{localize "PF2E_CRITICAL_FORGE.EffectForge.ImportExport"}}</h2>
          <span class="effect-forge-transfer-format">
            <i class="fa-solid fa-code-branch"></i>
            {{localize "PF2E_CRITICAL_FORGE.EffectForge.ExportFormatVersion"}} 1
          </span>
        </header>

        <div class="effect-forge-transfer-actions">
          <button type="button" data-action="importJsonFile">
            <i class="fa-solid fa-file-import"></i>
            {{localize "PF2E_CRITICAL_FORGE.EffectForge.ImportJsonFile"}}
          </button>
          <button type="button" data-action="importClipboard">
            <i class="fa-solid fa-clipboard"></i>
            {{localize "PF2E_CRITICAL_FORGE.EffectForge.ImportClipboard"}}
          </button>
          <button type="button" data-action="exportJson">
            <i class="fa-solid fa-file-export"></i>
            {{localize "PF2E_CRITICAL_FORGE.EffectForge.ExportJsonFile"}}
          </button>
          <button type="button" data-action="copyExport">
            <i class="fa-regular fa-copy"></i>
            {{localize "PF2E_CRITICAL_FORGE.EffectForge.CopyExport"}}
          </button>
        </div>

        <p class="effect-forge-transfer-hint">
          <i class="fa-solid fa-circle-info"></i>
          {{localize "PF2E_CRITICAL_FORGE.EffectForge.ImportExportHint"}}
        </p>
      </section>
      {{/if}}

      <section class="effect-forge-section">
        <h2>{{localize "PF2E_CRITICAL_FORGE.EffectForge.BasicData"}}</h2>

        <label class="effect-forge-field full-width">
          <span>{{localize "PF2E_CRITICAL_FORGE.EffectForge.Id"}}</span>
          <input type="text" name="effectId" value="{{state.effectId}}" required>
        </label>

        <div class="effect-forge-name-image-row">
          <label class="effect-forge-field">
            <span>{{localize "PF2E_CRITICAL_FORGE.EffectForge.Name"}}</span>
            <input type="text" name="effectName" value="{{state.effectName}}" required>
          </label>

          <div class="effect-forge-field effect-forge-image-field">
            <span>{{localize "PF2E_CRITICAL_FORGE.EffectForge.ImageOptional"}}</span>
            <div class="effect-forge-image-picker">
              <img src="{{state.img}}" alt="">
              <input type="hidden" name="img" value="{{state.img}}">
              <button type="button" class="effect-forge-browse-button" data-action="browseImage" title="{{localize 'PF2E_CRITICAL_FORGE.EffectForge.SelectImage'}}">
                <i class="fa-solid fa-ellipsis"></i>
              </button>
            </div>
          </div>
        </div>

        <label class="effect-forge-field full-width">
          <span>{{localize "PF2E_CRITICAL_FORGE.EffectForge.Description"}}</span>
          <textarea name="description" rows="3" maxlength="1000">{{state.description}}</textarea>
          <small class="effect-forge-character-count" data-description-counter>{{descriptionLength}} / 1000</small>
        </label>
      </section>

      <section class="effect-forge-section effect-forge-duration-section">
        <h2>{{localize "PF2E_CRITICAL_FORGE.EffectForge.Duration"}}</h2>

        <div class="effect-forge-grid three-columns">
          <label class="effect-forge-field">
            <span>{{localize "PF2E_CRITICAL_FORGE.EffectForge.Value"}}</span>
            <input data-duration-control type="number" name="durationValue" value="{{state.durationValue}}" min="0" step="1">
          </label>

          <label class="effect-forge-field">
            <span>{{localize "PF2E_CRITICAL_FORGE.EffectForge.Unit"}}</span>
            <select data-duration-control name="durationUnit">
              <option value="rounds" {{#if (eq state.durationUnit "rounds")}}selected{{/if}}>{{localize "PF2E_CRITICAL_FORGE.Duration.Rounds"}}</option>
              <option value="minutes" {{#if (eq state.durationUnit "minutes")}}selected{{/if}}>{{localize "PF2E_CRITICAL_FORGE.Duration.Minutes"}}</option>
              <option value="hours" {{#if (eq state.durationUnit "hours")}}selected{{/if}}>{{localize "PF2E_CRITICAL_FORGE.Duration.Hours"}}</option>
              <option value="days" {{#if (eq state.durationUnit "days")}}selected{{/if}}>{{localize "PF2E_CRITICAL_FORGE.Duration.Days"}}</option>
            </select>
          </label>

          <label class="effect-forge-field">
            <span>{{localize "PF2E_CRITICAL_FORGE.EffectForge.Expiry"}}</span>
            <select data-duration-control name="durationExpiry">
              <option value="turn-start" {{#if (eq state.durationExpiry "turn-start")}}selected{{/if}}>{{localize "PF2E_CRITICAL_FORGE.Duration.TurnStart"}}</option>
              <option value="turn-end" {{#if (eq state.durationExpiry "turn-end")}}selected{{/if}}>{{localize "PF2E_CRITICAL_FORGE.Duration.TurnEnd"}}</option>
              <option value="round-start" {{#if (eq state.durationExpiry "round-start")}}selected{{/if}}>{{localize "PF2E_CRITICAL_FORGE.Duration.RoundStart"}}</option>
              <option value="round-end" {{#if (eq state.durationExpiry "round-end")}}selected{{/if}}>{{localize "PF2E_CRITICAL_FORGE.Duration.RoundEnd"}}</option>
            </select>
          </label>
        </div>

        <label class="effect-forge-checkbox">
          <input type="checkbox" name="unlimitedDuration" {{#if unlimitedDuration}}checked{{/if}}>
          <span>{{localize "PF2E_CRITICAL_FORGE.EffectForge.UnlimitedDuration"}}</span>
        </label>
        <p class="effect-forge-field-hint">
          <i class="fa-solid fa-layer-group"></i>
          {{localize "PF2E_CRITICAL_FORGE.EffectForge.MultiDurationHint"}}
        </p>
      </section>

      <section class="effect-forge-section effect-forge-components-section">
        <header class="effect-forge-section-header">
          <h2>{{localize "PF2E_CRITICAL_FORGE.EffectForge.Components"}}</h2>

          <div class="effect-forge-add-component">
            <button type="button" class="primary" data-action="toggleComponentMenu">
              <i class="fa-solid fa-plus"></i>
              {{localize "PF2E_CRITICAL_FORGE.EffectForge.AddComponent"}}
            </button>

            {{#if componentMenuOpen}}
              <div class="effect-forge-component-menu">
                <button type="button" data-action="addCondition">
                  <i class="fa-solid fa-circle-exclamation"></i>
                  {{localize "PF2E_CRITICAL_FORGE.EffectForge.Condition"}}
                </button>
                <button type="button" data-action="addModifier">
                  <i class="fa-solid fa-sliders"></i>
                  {{localize "PF2E_CRITICAL_FORGE.EffectForge.Modifier"}}
                </button>
                <button type="button" data-action="addPersistentDamage">
                  <i class="fa-solid fa-droplet"></i>
                  {{localize "PF2E_CRITICAL_FORGE.EffectForge.PersistentDamage"}}
                </button>
                <button type="button" data-action="addResistance">
                  <i class="fa-solid fa-shield-halved"></i>
                  {{localize "PF2E_CRITICAL_FORGE.EffectForge.Resistance"}}
                </button>
                <button type="button" data-action="addWeakness">
                  <i class="fa-solid fa-burst"></i>
                  {{localize "PF2E_CRITICAL_FORGE.EffectForge.Weakness"}}
                </button>
                <button type="button" data-action="addImmunity">
                  <i class="fa-solid fa-shield"></i>
                  {{localize "PF2E_CRITICAL_FORGE.EffectForge.Immunity"}}
                </button>
                <button type="button" data-action="addFastHealing">
                  <i class="fa-solid fa-heart-pulse"></i>
                  {{localize "PF2E_CRITICAL_FORGE.EffectForge.FastHealing"}}
                </button>
                <button type="button" data-action="addRegeneration">
                  <i class="fa-solid fa-arrows-rotate"></i>
                  {{localize "PF2E_CRITICAL_FORGE.EffectForge.Regeneration"}}
                </button>
                <button type="button" data-action="addTemporaryHitPoints">
                  <i class="fa-solid fa-heart-circle-plus"></i>
                  {{localize "PF2E_CRITICAL_FORGE.EffectForge.TemporaryHitPoints"}}
                </button>
                <button type="button" data-action="addMovement">
                  <i class="fa-solid fa-person-running"></i>
                  {{localize "PF2E_CRITICAL_FORGE.EffectForge.Movement"}}
                </button>
                <button type="button" data-action="addBaseSpeed">
                  <i class="fa-solid fa-wind"></i>
                  {{localize "PF2E_CRITICAL_FORGE.EffectForge.BaseSpeed"}}
                </button>
              </div>
            {{/if}}
          </div>
        </header>

        <div class="effect-forge-component-list" data-preserve-scroll data-scroll-key="components" data-scroll-anchor="bottom">
          {{#each components as |component|}}
            <article
              class="effect-forge-component-card component-{{component.type}} {{#if component.collapsed}}collapsed{{/if}} {{#if component.hasValidationStatus}}validation-{{component.validationStatus.severity}}{{/if}}"
              data-component-index="{{component.index}}"
            >
              <header>
                <button
                  type="button"
                  class="effect-forge-component-collapse"
                  data-action="toggleComponentCollapsed"
                  data-index="{{component.index}}"
                  title="{{localize 'PF2E_CRITICAL_FORGE.EffectForge.ToggleComponent'}}"
                >
                  <i class="fa-solid {{#if component.collapsed}}fa-chevron-right{{else}}fa-chevron-down{{/if}}"></i>
                </button>
                <div class="effect-forge-component-title">
                  <span class="component-number">{{component.number}}</span>
                  <strong>
                    {{#if component.isCondition}}
                      {{localize "PF2E_CRITICAL_FORGE.EffectForge.Condition"}}
                    {{/if}}
                    {{#if component.isModifier}}
                      {{localize "PF2E_CRITICAL_FORGE.EffectForge.Modifier"}}
                    {{/if}}
                    {{#if component.isPersistentDamage}}
                      {{localize "PF2E_CRITICAL_FORGE.EffectForge.PersistentDamage"}}
                    {{/if}}
                    {{#if component.isResistance}}
                      {{localize "PF2E_CRITICAL_FORGE.EffectForge.Resistance"}}
                    {{/if}}
                    {{#if component.isWeakness}}
                      {{localize "PF2E_CRITICAL_FORGE.EffectForge.Weakness"}}
                    {{/if}}
                    {{#if component.isImmunity}}
                      {{localize "PF2E_CRITICAL_FORGE.EffectForge.Immunity"}}
                    {{/if}}
                    {{#if component.isFastHealing}}
                      {{localize "PF2E_CRITICAL_FORGE.EffectForge.FastHealing"}}
                    {{/if}}
                    {{#if component.isRegeneration}}
                      {{localize "PF2E_CRITICAL_FORGE.EffectForge.Regeneration"}}
                    {{/if}}
                    {{#if component.isTemporaryHitPoints}}
                      {{localize "PF2E_CRITICAL_FORGE.EffectForge.TemporaryHitPoints"}}
                    {{/if}}
                    {{#if component.isMovement}}
                      {{localize "PF2E_CRITICAL_FORGE.EffectForge.Movement"}}
                    {{/if}}
                    {{#if component.isBaseSpeed}}
                      {{localize "PF2E_CRITICAL_FORGE.EffectForge.BaseSpeed"}}
                    {{/if}}
                  </strong>
                </div>

                <div class="effect-forge-component-header-actions">
                  {{#if component.hasValidationStatus}}
                    <span class="effect-forge-component-validation severity-{{component.validationStatus.severity}}" title="{{component.validationStatus.title}}">
                      <i class="fa-solid {{component.validationStatus.icon}}"></i>
                      {{component.validationStatus.count}}
                    </span>
                  {{/if}}
                  <button type="button" class="icon" data-action="moveComponentUp" data-index="{{component.index}}" title="{{localize 'PF2E_CRITICAL_FORGE.EffectForge.MoveComponentUp'}}" {{#unless component.canMoveUp}}disabled{{/unless}}>
                    <i class="fa-solid fa-arrow-up"></i>
                  </button>
                  <button type="button" class="icon" data-action="moveComponentDown" data-index="{{component.index}}" title="{{localize 'PF2E_CRITICAL_FORGE.EffectForge.MoveComponentDown'}}" {{#unless component.canMoveDown}}disabled{{/unless}}>
                    <i class="fa-solid fa-arrow-down"></i>
                  </button>
                  <button type="button" class="icon" data-action="duplicateComponent" data-index="{{component.index}}" title="{{localize 'PF2E_CRITICAL_FORGE.EffectForge.DuplicateComponent'}}">
                    <i class="fa-regular fa-copy"></i>
                  </button>
                  <button type="button" class="icon danger" data-action="removeComponent" data-index="{{component.index}}" title="{{localize 'PF2E_CRITICAL_FORGE.EffectForge.RemoveComponent'}}">
                    <i class="fa-solid fa-trash"></i>
                  </button>
                </div>
              </header>

              {{#if component.collapsed}}
                <p class="effect-forge-component-summary">{{component.summary}}</p>
              {{else}}

              {{#if component.isCondition}}
                <div class="effect-forge-grid condition-grid">
                  <label class="effect-forge-field">
                    <span>{{localize "PF2E_CRITICAL_FORGE.EffectForge.Condition"}}</span>
                    <select name="components.{{component.index}}.slug" data-condition-choice>
                      {{#each component.conditionOptions as |option|}}
                        <option
                          value="{{option.value}}"
                          data-valued="{{option.isValued}}"
                          {{#if option.selected}}selected{{/if}}
                        >{{option.label}}</option>
                      {{/each}}
                    </select>
                  </label>

                  <label
                    class="effect-forge-field"
                    data-condition-value-field
                    {{#unless component.isValuedCondition}}hidden{{/unless}}
                  >
                    <span>{{localize "PF2E_CRITICAL_FORGE.EffectForge.Value"}}</span>
                    <input
                      type="number"
                      name="components.{{component.index}}.value"
                      value="{{component.value}}"
                      min="0"
                      step="1"
                      {{#unless component.isValuedCondition}}disabled{{/unless}}
                    >
                  </label>
                </div>
              {{/if}}

              {{#if component.isModifier}}
                <div class="effect-forge-grid modifier-grid">
                  <label class="effect-forge-field">
                    <span>{{localize "PF2E_CRITICAL_FORGE.EffectForge.Selector"}}</span>
                    <select name="components.{{component.index}}.selectorChoice" data-selector-choice>
                      {{#each component.selectorGroups as |group|}}
                        <optgroup label="{{group.label}}">
                          {{#each group.options as |option|}}
                            <option value="{{option.value}}" {{#if option.selected}}selected{{/if}}>{{option.label}}</option>
                          {{/each}}
                        </optgroup>
                      {{/each}}
                    </select>
                  </label>

                  <label class="effect-forge-field">
                    <span>{{localize "PF2E_CRITICAL_FORGE.EffectForge.ModifierType"}}</span>
                    <select name="components.{{component.index}}.modifierType">
                      {{#each component.modifierTypeOptions as |option|}}
                        <option value="{{option.value}}" {{#if option.selected}}selected{{/if}}>{{option.label}}</option>
                      {{/each}}
                    </select>
                  </label>

                  <label class="effect-forge-field">
                    <span>{{localize "PF2E_CRITICAL_FORGE.EffectForge.Value"}}</span>
                    <input type="number" name="components.{{component.index}}.value" value="{{component.value}}" step="1">
                  </label>
                </div>

                <label class="effect-forge-field effect-forge-custom-selector" data-custom-selector-field {{#unless component.usesCustomSelector}}hidden{{/unless}}>
                  <span>{{localize "PF2E_CRITICAL_FORGE.EffectForge.CustomSelector"}}</span>
                  <input
                    type="text"
                    name="components.{{component.index}}.customSelector"
                    value="{{component.customSelector}}"
                    placeholder="{{localize 'PF2E_CRITICAL_FORGE.EffectForge.CustomSelectorPlaceholder'}}"
                    {{#unless component.usesCustomSelector}}disabled{{/unless}}
                    {{#if component.usesCustomSelector}}required{{/if}}
                  >
                  <small class="effect-forge-field-hint">{{localize "PF2E_CRITICAL_FORGE.EffectForge.CustomSelectorHint"}}</small>
                </label>
              {{/if}}

              {{#if component.isPersistentDamage}}
                <div class="effect-forge-grid persistent-damage-grid">
                  <label class="effect-forge-field">
                    <span>{{localize "PF2E_CRITICAL_FORGE.EffectForge.DamageFormula"}}</span>
                    <input
                      type="text"
                      name="components.{{component.index}}.formula"
                      value="{{component.formula}}"
                      placeholder="1d6"
                      required
                    >
                  </label>

                  <label class="effect-forge-field">
                    <span>{{localize "PF2E_CRITICAL_FORGE.EffectForge.DamageType"}}</span>
                    <select name="components.{{component.index}}.damageType">
                      {{#each component.damageTypeGroups as |group|}}
                        <optgroup label="{{group.label}}">
                          {{#each group.options as |option|}}
                            <option value="{{option.value}}" {{#if option.selected}}selected{{/if}}>{{option.label}}</option>
                          {{/each}}
                        </optgroup>
                      {{/each}}
                    </select>
                  </label>

                  <label class="effect-forge-field">
                    <span>{{localize "PF2E_CRITICAL_FORGE.EffectForge.RecoveryDC"}}</span>
                    <input
                      type="number"
                      name="components.{{component.index}}.dc"
                      value="{{component.dc}}"
                      min="1"
                      step="1"
                      placeholder="15"
                    >
                    <small class="effect-forge-field-hint">{{localize "PF2E_CRITICAL_FORGE.EffectForge.RecoveryDCHint"}}</small>
                  </label>
                </div>
              {{/if}}

              {{#if component.isResistance}}
                <div class="effect-forge-grid resistance-grid">
                  <label class="effect-forge-field">
                    <span>{{localize "PF2E_CRITICAL_FORGE.EffectForge.ResistanceType"}}</span>
                    <select name="components.{{component.index}}.resistanceType">
                      {{#each component.resistanceTypeGroups as |group|}}
                        <optgroup label="{{group.label}}">
                          {{#each group.options as |option|}}
                            <option value="{{option.value}}" {{#if option.selected}}selected{{/if}}>{{option.label}}</option>
                          {{/each}}
                        </optgroup>
                      {{/each}}
                    </select>
                  </label>

                  <label class="effect-forge-field">
                    <span>{{localize "PF2E_CRITICAL_FORGE.EffectForge.ResistanceValue"}}</span>
                    <input
                      type="number"
                      name="components.{{component.index}}.value"
                      value="{{component.value}}"
                      min="1"
                      step="1"
                      required
                    >
                  </label>
                </div>
              {{/if}}

              {{#if component.isWeakness}}
                <div class="effect-forge-grid weakness-grid">
                  <label class="effect-forge-field">
                    <span>{{localize "PF2E_CRITICAL_FORGE.EffectForge.WeaknessType"}}</span>
                    <select name="components.{{component.index}}.weaknessType">
                      {{#each component.weaknessTypeGroups as |group|}}
                        <optgroup label="{{group.label}}">
                          {{#each group.options as |option|}}
                            <option value="{{option.value}}" {{#if option.selected}}selected{{/if}}>{{option.label}}</option>
                          {{/each}}
                        </optgroup>
                      {{/each}}
                    </select>
                  </label>

                  <label class="effect-forge-field">
                    <span>{{localize "PF2E_CRITICAL_FORGE.EffectForge.WeaknessValue"}}</span>
                    <input
                      type="number"
                      name="components.{{component.index}}.value"
                      value="{{component.value}}"
                      min="1"
                      step="1"
                      required
                    >
                  </label>
                </div>
              {{/if}}

              {{#if component.isImmunity}}
                <div class="effect-forge-grid immunity-grid">
                  <label class="effect-forge-field">
                    <span>{{localize "PF2E_CRITICAL_FORGE.EffectForge.ImmunityType"}}</span>
                    <select name="components.{{component.index}}.immunityType">
                      {{#each component.immunityTypeGroups as |group|}}
                        <optgroup label="{{group.label}}">
                          {{#each group.options as |option|}}
                            <option value="{{option.value}}" {{#if option.selected}}selected{{/if}}>{{option.label}}</option>
                          {{/each}}
                        </optgroup>
                      {{/each}}
                    </select>
                  </label>
                </div>
              {{/if}}

              {{#if component.isFastHealing}}
                <div class="effect-forge-grid fast-healing-grid">
                  <label class="effect-forge-field">
                    <span>{{localize "PF2E_CRITICAL_FORGE.EffectForge.FastHealingValue"}}</span>
                    <input
                      type="number"
                      name="components.{{component.index}}.value"
                      value="{{component.value}}"
                      min="1"
                      step="1"
                      required
                    >
                    <small class="effect-forge-field-hint">{{localize "PF2E_CRITICAL_FORGE.EffectForge.FastHealingHint"}}</small>
                  </label>
                </div>
              {{/if}}


              {{#if component.isTemporaryHitPoints}}
                <div class="effect-forge-grid temporary-hit-points-grid">
                  <label class="effect-forge-field">
                    <span>{{localize "PF2E_CRITICAL_FORGE.EffectForge.TemporaryHitPointsValue"}}</span>
                    <input
                      type="number"
                      name="components.{{component.index}}.value"
                      value="{{component.value}}"
                      min="1"
                      step="1"
                      required
                    >
                    <small class="effect-forge-field-hint">{{localize "PF2E_CRITICAL_FORGE.EffectForge.TemporaryHitPointsHint"}}</small>
                  </label>
                </div>
              {{/if}}

              {{#if component.isMovement}}
                <div class="effect-forge-grid movement-grid">
                  <label class="effect-forge-field">
                    <span>{{localize "PF2E_CRITICAL_FORGE.EffectForge.MovementType"}}</span>
                    <select name="components.{{component.index}}.movementType">
                      {{#each component.movementTypeGroups as |group|}}
                        <optgroup label="{{group.label}}">
                          {{#each group.options as |option|}}
                            <option value="{{option.value}}" {{#if option.selected}}selected{{/if}}>{{option.label}}</option>
                          {{/each}}
                        </optgroup>
                      {{/each}}
                    </select>
                  </label>

                  <label class="effect-forge-field">
                    <span>{{localize "PF2E_CRITICAL_FORGE.EffectForge.ModifierType"}}</span>
                    <select name="components.{{component.index}}.modifierType">
                      {{#each component.modifierTypeOptions as |option|}}
                        <option value="{{option.value}}" {{#if option.selected}}selected{{/if}}>{{option.label}}</option>
                      {{/each}}
                    </select>
                  </label>

                  <label class="effect-forge-field">
                    <span>{{localize "PF2E_CRITICAL_FORGE.EffectForge.MovementValue"}}</span>
                    <input
                      type="number"
                      name="components.{{component.index}}.value"
                      value="{{component.value}}"
                      step="5"
                      required
                    >
                    <small class="effect-forge-field-hint">{{localize "PF2E_CRITICAL_FORGE.EffectForge.MovementHint"}}</small>
                  </label>
                </div>
              {{/if}}

              {{#if component.isBaseSpeed}}
                <div class="effect-forge-grid base-speed-grid">
                  <label class="effect-forge-field">
                    <span>{{localize "PF2E_CRITICAL_FORGE.EffectForge.BaseSpeedType"}}</span>
                    <select name="components.{{component.index}}.movementType">
                      {{#each component.baseSpeedTypeGroups as |group|}}
                        <optgroup label="{{group.label}}">
                          {{#each group.options as |option|}}
                            <option value="{{option.value}}" {{#if option.selected}}selected{{/if}}>{{option.label}}</option>
                          {{/each}}
                        </optgroup>
                      {{/each}}
                    </select>
                  </label>

                  <label class="effect-forge-field">
                    <span>{{localize "PF2E_CRITICAL_FORGE.EffectForge.BaseSpeedValue"}}</span>
                    <input
                      type="number"
                      name="components.{{component.index}}.value"
                      value="{{component.value}}"
                      min="1"
                      step="5"
                      required
                    >
                    <small class="effect-forge-field-hint">{{localize "PF2E_CRITICAL_FORGE.EffectForge.BaseSpeedHint"}}</small>
                  </label>
                </div>
              {{/if}}

              {{#if component.isRegeneration}}
                <div class="effect-forge-grid regeneration-grid">
                  <label class="effect-forge-field">
                    <span>{{localize "PF2E_CRITICAL_FORGE.EffectForge.RegenerationValue"}}</span>
                    <input
                      type="number"
                      name="components.{{component.index}}.value"
                      value="{{component.value}}"
                      min="1"
                      step="1"
                      required
                    >
                    <small class="effect-forge-field-hint">{{localize "PF2E_CRITICAL_FORGE.EffectForge.RegenerationHint"}}</small>
                  </label>

                  <label class="effect-forge-field">
                    <span>{{localize "PF2E_CRITICAL_FORGE.EffectForge.RegenerationDeactivatedBy"}}</span>
                    <select name="components.{{component.index}}.deactivatedBy" multiple size="7" required>
                      {{#each component.damageTypeGroups as |group|}}
                        <optgroup label="{{group.label}}">
                          {{#each group.options as |option|}}
                            <option value="{{option.value}}" {{#if option.selected}}selected{{/if}}>{{option.label}}</option>
                          {{/each}}
                        </optgroup>
                      {{/each}}
                    </select>
                    <small class="effect-forge-field-hint">{{localize "PF2E_CRITICAL_FORGE.EffectForge.RegenerationDeactivatedByHint"}}</small>
                  </label>
                </div>
              {{/if}}

              <section class="effect-forge-component-duration" data-component-duration>
                <header>
                  <label class="effect-forge-checkbox">
                    <input
                      type="checkbox"
                      name="components.{{component.index}}.durationOverride"
                      data-component-duration-override
                      {{#if component.hasDurationOverride}}checked{{/if}}
                    >
                    <span>{{localize "PF2E_CRITICAL_FORGE.EffectForge.ComponentDurationOverride"}}</span>
                  </label>
                  <small>{{localize "PF2E_CRITICAL_FORGE.EffectForge.ComponentDurationInheritanceHint"}}</small>
                </header>

                <div class="effect-forge-grid three-columns">
                  <label class="effect-forge-field">
                    <span>{{localize "PF2E_CRITICAL_FORGE.EffectForge.Value"}}</span>
                    <input
                      type="number"
                      name="components.{{component.index}}.durationValue"
                      value="{{component.componentDurationValue}}"
                      min="0"
                      step="1"
                      data-component-duration-control
                      {{#unless component.hasDurationOverride}}disabled{{/unless}}
                      {{#if component.componentUnlimitedDuration}}disabled{{/if}}
                    >
                  </label>

                  <label class="effect-forge-field">
                    <span>{{localize "PF2E_CRITICAL_FORGE.EffectForge.Unit"}}</span>
                    <select
                      name="components.{{component.index}}.durationUnit"
                      data-component-duration-control
                      {{#unless component.hasDurationOverride}}disabled{{/unless}}
                      {{#if component.componentUnlimitedDuration}}disabled{{/if}}
                    >
                      <option value="rounds" {{#if (eq component.componentDurationUnit "rounds")}}selected{{/if}}>{{localize "PF2E_CRITICAL_FORGE.Duration.Rounds"}}</option>
                      <option value="minutes" {{#if (eq component.componentDurationUnit "minutes")}}selected{{/if}}>{{localize "PF2E_CRITICAL_FORGE.Duration.Minutes"}}</option>
                      <option value="hours" {{#if (eq component.componentDurationUnit "hours")}}selected{{/if}}>{{localize "PF2E_CRITICAL_FORGE.Duration.Hours"}}</option>
                      <option value="days" {{#if (eq component.componentDurationUnit "days")}}selected{{/if}}>{{localize "PF2E_CRITICAL_FORGE.Duration.Days"}}</option>
                    </select>
                  </label>

                  <label class="effect-forge-field">
                    <span>{{localize "PF2E_CRITICAL_FORGE.EffectForge.Expiry"}}</span>
                    <select
                      name="components.{{component.index}}.durationExpiry"
                      data-component-duration-control
                      {{#unless component.hasDurationOverride}}disabled{{/unless}}
                      {{#if component.componentUnlimitedDuration}}disabled{{/if}}
                    >
                      <option value="turn-start" {{#if (eq component.componentDurationExpiry "turn-start")}}selected{{/if}}>{{localize "PF2E_CRITICAL_FORGE.Duration.TurnStart"}}</option>
                      <option value="turn-end" {{#if (eq component.componentDurationExpiry "turn-end")}}selected{{/if}}>{{localize "PF2E_CRITICAL_FORGE.Duration.TurnEnd"}}</option>
                      <option value="round-start" {{#if (eq component.componentDurationExpiry "round-start")}}selected{{/if}}>{{localize "PF2E_CRITICAL_FORGE.Duration.RoundStart"}}</option>
                      <option value="round-end" {{#if (eq component.componentDurationExpiry "round-end")}}selected{{/if}}>{{localize "PF2E_CRITICAL_FORGE.Duration.RoundEnd"}}</option>
                    </select>
                  </label>
                </div>

                <label class="effect-forge-checkbox effect-forge-component-unlimited">
                  <input
                    type="checkbox"
                    name="components.{{component.index}}.unlimitedDuration"
                    data-component-duration-unlimited
                    {{#if component.componentUnlimitedDuration}}checked{{/if}}
                    {{#unless component.hasDurationOverride}}disabled{{/unless}}
                  >
                  <span>{{localize "PF2E_CRITICAL_FORGE.EffectForge.UnlimitedDuration"}}</span>
                </label>
              </section>
              {{/if}}
            </article>
          {{else}}
            <div class="effect-forge-empty">
              <i class="fa-solid fa-cubes"></i>
              <p>{{localize "PF2E_CRITICAL_FORGE.EffectForge.NoComponents"}}</p>
            </div>
          {{/each}}
        </div>
      </section>
    </main>

    <aside class="effect-forge-sidebar">
      <section class="effect-forge-panel effect-forge-validation">
        <header class="effect-forge-panel-header">
          <h2>{{localize "PF2E_CRITICAL_FORGE.EffectForge.ValidationReport"}}</h2>
          {{#if validationReport}}
            <span class="effect-forge-validation-status {{validationReport.statusClass}}">
              <i class="fa-solid {{validationReport.statusIcon}}"></i>
              {{validationReport.statusText}}
            </span>
          {{else}}
            <span class="effect-forge-validation-status neutral">
              <i class="fa-solid fa-circle-minus"></i>
              {{localize "PF2E_CRITICAL_FORGE.EffectForge.Validation.NotValidated"}}
            </span>
          {{/if}}
        </header>

        {{#if validationReport}}
          {{#if validationReport.hasIssues}}
            <div class="effect-forge-validation-groups" data-preserve-scroll data-scroll-key="validation">
              {{#each validationReport.groups as |group|}}
                <details class="effect-forge-validation-group severity-{{group.severity}}" open>
                  <summary>
                    <span><i class="fa-solid {{group.icon}}"></i> {{group.label}} ({{group.count}})</span>
                    <i class="fa-solid fa-chevron-down"></i>
                  </summary>
                  <div class="effect-forge-validation-items">
                    {{#each group.issues as |issue|}}
                      <article>
                        <p>{{issue.text}}</p>
                        <div class="effect-forge-validation-meta">
                          <small>{{localize "PF2E_CRITICAL_FORGE.EffectForge.Validation.Code"}}: {{issue.code}}</small>
                          {{#if issue.hasComponent}}
                            <button type="button" data-action="focusComponent" data-index="{{issue.componentIndex}}">
                              <i class="fa-solid fa-crosshairs"></i>
                              {{localize "PF2E_CRITICAL_FORGE.EffectForge.GoToComponent"}} {{issue.componentNumber}}
                            </button>
                          {{/if}}
                        </div>
                      </article>
                    {{/each}}
                  </div>
                </details>
              {{/each}}
            </div>
          {{else}}
            <p class="effect-forge-valid-message">
              <i class="fa-solid fa-circle-check"></i>
              {{localize "PF2E_CRITICAL_FORGE.EffectForge.NoValidationIssues"}}
            </p>
          {{/if}}
        {{/if}}
      </section>

      <section class="effect-forge-panel effect-forge-preview">
        <header class="effect-forge-panel-header">
          <h2>{{localize "PF2E_CRITICAL_FORGE.EffectForge.DefinitionPreviewJson"}}</h2>
          <button type="button" class="effect-forge-copy-button" data-action="copyDefinition" {{#unless definitionPreview}}disabled{{/unless}}>
            <i class="fa-regular fa-copy"></i>
            {{localize "PF2E_CRITICAL_FORGE.EffectForge.CopyClipboard"}}
          </button>
        </header>
        {{#if definitionPreview}}
          <pre data-preserve-scroll data-scroll-key="definition-preview">{{definitionPreview}}</pre>
        {{else}}
          <p class="effect-forge-preview-empty">{{localize "PF2E_CRITICAL_FORGE.EffectForge.PreviewEmpty"}}</p>
        {{/if}}
      </section>

      <section class="effect-forge-panel effect-forge-preview">
        <header class="effect-forge-panel-header">
          <h2>{{localize "PF2E_CRITICAL_FORGE.EffectForge.CompiledPreviewRules"}}</h2>
          <button type="button" class="effect-forge-copy-button" data-action="copyCompiled" {{#unless compiledPreview}}disabled{{/unless}}>
            <i class="fa-regular fa-copy"></i>
            {{localize "PF2E_CRITICAL_FORGE.EffectForge.CopyClipboard"}}
          </button>
        </header>
        {{#if compiledPreview}}
          <pre data-preserve-scroll data-scroll-key="compiled-preview">{{compiledPreview}}</pre>
        {{else}}
          <p class="effect-forge-preview-empty">{{localize "PF2E_CRITICAL_FORGE.EffectForge.CompiledEmpty"}}</p>
        {{/if}}
      </section>
    </aside>
  </div>

  <footer class="effect-forge-actions {{#if externalMode}}external-mode{{/if}}">
    <button type="button" class="{{#unless externalMode}}primary{{/unless}}" data-action="validateEffect" title="{{localize 'PF2E_CRITICAL_FORGE.EffectForge.ValidateTooltip'}}">
      <i class="fa-solid fa-gear"></i>
      {{localize "PF2E_CRITICAL_FORGE.EffectForge.Validate"}}
    </button>
    <button type="button" data-action="compileEffect" title="{{localize 'PF2E_CRITICAL_FORGE.EffectForge.CompileTooltip'}}">
      <i class="fa-solid fa-code"></i>
      {{localize "PF2E_CRITICAL_FORGE.EffectForge.Compile"}}
    </button>

    {{#if externalMode}}
      <button type="button" class="primary effect-forge-external-commit" data-action="commitExternal" title="{{localize 'PF2E_CRITICAL_FORGE.EffectForge.ExternalCommitHint'}}">
        <i class="fa-solid fa-arrow-right-to-bracket"></i>
        {{localize "PF2E_CRITICAL_FORGE.EffectForge.ExternalCommit"}}
      </button>
    {{else}}
      <button type="button" data-action="createItem" title="{{localize 'PF2E_CRITICAL_FORGE.EffectForge.CreateItemTooltip'}}">
        <i class="fa-regular fa-file-lines"></i>
        {{localize "PF2E_CRITICAL_FORGE.EffectForge.CreateNewItem"}}
      </button>
      <button type="button" class="effect-forge-update-button" data-action="updateItem" title="{{#if editingItem}}{{localize 'PF2E_CRITICAL_FORGE.EffectForge.UpdateItemTooltip'}}{{else}}{{localize 'PF2E_CRITICAL_FORGE.EffectForge.UpdateItemDisabledTooltip'}}{{/if}}" {{#unless editingItem}}disabled{{/unless}}>
        <i class="fa-solid fa-floppy-disk"></i>
        {{localize "PF2E_CRITICAL_FORGE.EffectForge.UpdateItem"}}
      </button>
      <button type="button" data-action="applySelected" title="{{#if hasSelectedTokens}}{{localize 'PF2E_CRITICAL_FORGE.EffectForge.ApplySelectedTooltip'}}{{else}}{{localize 'PF2E_CRITICAL_FORGE.EffectForge.ApplySelectedDisabledTooltip'}}{{/if}}" {{#unless hasSelectedTokens}}disabled{{/unless}}>
        <i class="fa-solid fa-user-group"></i>
        {{localize "PF2E_CRITICAL_FORGE.EffectForge.ApplySelected"}}
      </button>
    {{/if}}

    <button type="button" data-action="closeWindow">
      <i class="fa-solid fa-xmark"></i>
      {{localize "PF2E_CRITICAL_FORGE.EffectForge.Close"}}
    </button>
  </footer>
</div>
