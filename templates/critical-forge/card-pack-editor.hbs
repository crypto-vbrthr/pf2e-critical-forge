<div class="card-editor-shell">
  <header class="card-editor-toolbar">
    <div class="card-editor-title-block">
      <h2><i class="fa-solid fa-layer-group"></i> {{localize "PF2E_CRITICAL_FORGE.CardEditor.Title"}}</h2>
      <span class="card-editor-dirty {{#if isDirty}}dirty{{else}}clean{{/if}}" data-dirty-indicator>
        <i class="fa-solid {{#if isDirty}}fa-circle{{else}}fa-circle-check{{/if}}"></i>
        <span data-dirty-text>{{#if isDirty}}{{localize "PF2E_CRITICAL_FORGE.CardEditor.Unsaved"}}{{else}}{{localize "PF2E_CRITICAL_FORGE.CardEditor.Saved"}}{{/if}}</span>
      </span>
    </div>
    <div class="card-editor-toolbar-actions">
      <button type="button" data-action="newPack"><i class="fa-solid fa-plus"></i> {{localize "PF2E_CRITICAL_FORGE.CardEditor.NewPack"}}</button>
      <button type="button" data-action="duplicatePack" {{#unless hasPack}}disabled{{/unless}}><i class="fa-solid fa-copy"></i> {{localize "PF2E_CRITICAL_FORGE.CardEditor.DuplicatePack"}}</button>
      <button type="button" data-action="importFile"><i class="fa-solid fa-file-import"></i> {{localize "PF2E_CRITICAL_FORGE.CardEditor.ImportFile"}}</button>
      <button type="button" data-action="importClipboard"><i class="fa-solid fa-paste"></i> {{localize "PF2E_CRITICAL_FORGE.CardEditor.ImportClipboard"}}</button>
      <button type="button" data-action="exportPack" {{#unless hasPack}}disabled{{/unless}} title="{{exportFilename}}"><i class="fa-solid fa-file-export"></i> {{localize "PF2E_CRITICAL_FORGE.CardEditor.ExportFile"}}</button>
      <button type="button" data-action="copyPack" {{#unless hasPack}}disabled{{/unless}}><i class="fa-solid fa-copy"></i> {{localize "PF2E_CRITICAL_FORGE.CardEditor.CopyJson"}}</button>
    </div>
  </header>

  <main class="card-editor-main">
    <aside class="card-editor-list-panel pack-list-panel">
      <div class="card-editor-panel-heading">
        <h3>{{localize "PF2E_CRITICAL_FORGE.CardEditor.Packs"}}</h3>
        <span>{{packs.length}}</span>
      </div>
      <div class="card-editor-scroll-list" data-preserve-scroll data-scroll-key="card-editor-packs">
        {{#each packs as |entry|}}
          <button type="button" class="card-editor-list-entry {{#if entry.selected}}selected{{/if}}" data-action="selectPack" data-pack-id="{{entry.id}}">
            <span class="entry-icon"><i class="fa-solid {{#if entry.editable}}fa-pen-to-square{{else}}fa-lock{{/if}}"></i></span>
            <span class="entry-text">
              <strong>{{entry.title}}</strong>
              <small>{{entry.id}} · {{entry.cardCount}} {{localize "PF2E_CRITICAL_FORGE.CardEditor.CardsShort"}}</small>
            </span>
            {{#unless entry.enabled}}<i class="fa-solid fa-eye-slash"></i>{{/unless}}
          </button>
        {{/each}}
      </div>
    </aside>

    <aside class="card-editor-list-panel card-list-panel">
      <div class="card-editor-panel-heading">
        <h3>{{localize "PF2E_CRITICAL_FORGE.CardEditor.Cards"}}</h3>
        <button type="button" class="icon" data-action="newCard" title="{{localize 'PF2E_CRITICAL_FORGE.CardEditor.NewCard'}}" {{#unless packEditable}}disabled{{/unless}}><i class="fa-solid fa-plus"></i></button>
      </div>
      <div class="card-editor-scroll-list" data-preserve-scroll data-scroll-key="card-editor-cards">
        {{#each cards as |entry|}}
          <button type="button" class="card-editor-list-entry card-entry {{#if entry.selected}}selected{{/if}}" data-action="selectCard" data-card-id="{{entry.id}}">
            <span class="entry-icon"><i class="fa-solid {{#if entry.hasEffect}}fa-bolt{{else}}fa-feather{{/if}}"></i></span>
            <span class="entry-text">
              <strong>{{entry.title}}</strong>
              <small>{{entry.category}} · {{entry.tone}} · {{entry.impact}}</small>
            </span>
          </button>
        {{else}}
          <div class="card-editor-empty">{{localize "PF2E_CRITICAL_FORGE.CardEditor.NoCards"}}</div>
        {{/each}}
      </div>
    </aside>

    <section class="card-editor-workspace" data-preserve-scroll data-scroll-key="card-editor-workspace">
      {{#if hasPack}}
        <section class="card-editor-section pack-fields">
          <div class="card-editor-section-heading">
            <h3>{{localize "PF2E_CRITICAL_FORGE.CardEditor.PackSettings"}}</h3>
            <span class="card-editor-badge {{#if packEditable}}editable{{else}}readonly{{/if}}">{{packStatusLabel}}</span>
          </div>
          <div class="card-editor-grid pack-grid">
            <label><span>{{localize "PF2E_CRITICAL_FORGE.CardEditor.Id"}}</span><input name="pack.id" value="{{pack.id}}" {{#unless packEditable}}disabled{{/unless}}></label>
            <label><span>{{localize "PF2E_CRITICAL_FORGE.CardEditor.Version"}}</span><input name="pack.version" value="{{pack.version}}" {{#unless packEditable}}disabled{{/unless}}></label>
            <label class="wide"><span>{{localize "PF2E_CRITICAL_FORGE.CardEditor.TitleFallback"}}</span><input name="pack.fallbackTitle" value="{{pack.fallbackTitle}}" {{#unless packEditable}}disabled{{/unless}}></label>
            <label class="wide"><span>{{localize "PF2E_CRITICAL_FORGE.CardEditor.DescriptionFallback"}}</span><textarea name="pack.fallbackDescription" rows="2" {{#unless packEditable}}disabled{{/unless}}>{{pack.fallbackDescription}}</textarea></label>
            <label class="wide advanced"><span>{{localize "PF2E_CRITICAL_FORGE.CardEditor.TitleKey"}}</span><input name="pack.titleKey" value="{{pack.titleKey}}" {{#unless packEditable}}disabled{{/unless}}></label>
            <label class="wide advanced"><span>{{localize "PF2E_CRITICAL_FORGE.CardEditor.DescriptionKey"}}</span><input name="pack.descriptionKey" value="{{pack.descriptionKey}}" {{#unless packEditable}}disabled{{/unless}}></label>
            <label><span>{{localize "PF2E_CRITICAL_FORGE.CardEditor.Priority"}}</span><input type="number" name="pack.priority" value="{{pack.priority}}" step="1" {{#unless packEditable}}disabled{{/unless}}></label>
            <label class="checkbox-field"><input type="checkbox" name="pack.enabled" {{#if pack.enabled}}checked{{/if}} {{#unless packEditable}}disabled{{/unless}}> <span>{{localize "PF2E_CRITICAL_FORGE.CardEditor.Enabled"}}</span></label>
          </div>
        </section>

        {{#if hasCard}}
          <section class="card-editor-section card-fields">
            <div class="card-editor-section-heading">
              <h3>{{localize "PF2E_CRITICAL_FORGE.CardEditor.CardSettings"}}</h3>
              <div class="card-editor-inline-actions">
                <button type="button" data-action="duplicateCard"><i class="fa-solid fa-copy"></i> {{#if packEditable}}{{localize "PF2E_CRITICAL_FORGE.CardEditor.DuplicateCard"}}{{else}}{{localize "PF2E_CRITICAL_FORGE.CardEditor.CopyAsTemplate"}}{{/if}}</button>
                <button type="button" class="danger" data-action="deleteCard" {{#unless canEditCard}}disabled{{/unless}}><i class="fa-solid fa-trash"></i> {{localize "PF2E_CRITICAL_FORGE.CardEditor.DeleteCard"}}</button>
              </div>
            </div>

            <div class="card-editor-grid card-grid">
              <label class="wide"><span>{{localize "PF2E_CRITICAL_FORGE.CardEditor.Id"}}</span><input name="card.id" value="{{card.id}}" {{#unless packEditable}}disabled{{/unless}}></label>
              <label><span>{{localize "PF2E_CRITICAL_FORGE.CardEditor.Category"}}</span><select name="card.category" {{#unless packEditable}}disabled{{/unless}}>{{#each card.categoryOptions as |option|}}<option value="{{option.value}}" {{#if option.selected}}selected{{/if}}>{{option.label}}</option>{{/each}}</select></label>
              <label><span>{{localize "PF2E_CRITICAL_FORGE.CardEditor.Tone"}}</span><select name="card.tone" {{#unless packEditable}}disabled{{/unless}}>{{#each card.toneOptions as |option|}}<option value="{{option.value}}" {{#if option.selected}}selected{{/if}}>{{option.label}}</option>{{/each}}</select></label>
              <label><span>{{localize "PF2E_CRITICAL_FORGE.CardEditor.Impact"}}</span><select name="card.impact" {{#unless packEditable}}disabled{{/unless}}>{{#each card.impactOptions as |option|}}<option value="{{option.value}}" {{#if option.selected}}selected{{/if}}>{{option.label}}</option>{{/each}}</select></label>
              <label><span>{{localize "PF2E_CRITICAL_FORGE.CardEditor.Weight"}}</span><input type="number" name="card.weight" value="{{card.weight}}" min="0.01" step="0.25" {{#unless packEditable}}disabled{{/unless}}></label>
              <label class="wide"><span>{{localize "PF2E_CRITICAL_FORGE.CardEditor.TitleFallback"}}</span><input name="card.fallbackTitle" value="{{card.fallbackTitle}}" {{#unless packEditable}}disabled{{/unless}}></label>
              <label class="wide"><span>{{localize "PF2E_CRITICAL_FORGE.CardEditor.DescriptionFallback"}}</span><textarea name="card.fallbackDescription" rows="3" {{#unless packEditable}}disabled{{/unless}}>{{card.fallbackDescription}}</textarea></label>
              <label class="wide advanced"><span>{{localize "PF2E_CRITICAL_FORGE.CardEditor.TitleKey"}}</span><input name="card.titleKey" value="{{card.titleKey}}" {{#unless packEditable}}disabled{{/unless}}></label>
              <label class="wide advanced"><span>{{localize "PF2E_CRITICAL_FORGE.CardEditor.DescriptionKey"}}</span><input name="card.descriptionKey" value="{{card.descriptionKey}}" {{#unless packEditable}}disabled{{/unless}}></label>
              <label class="wide"><span>{{localize "PF2E_CRITICAL_FORGE.CardEditor.Tags"}}</span><input name="card.tags" value="{{card.tagsText}}" placeholder="bleed, melee, rare" {{#unless packEditable}}disabled{{/unless}}></label>
            </div>

            <details class="card-editor-details" open>
              <summary>{{localize "PF2E_CRITICAL_FORGE.CardEditor.Filters"}}</summary>
              <p class="hint">{{localize "PF2E_CRITICAL_FORGE.CardEditor.FiltersHint"}}</p>
              <div class="card-editor-grid filter-grid">
                <label><span>{{localize "PF2E_CRITICAL_FORGE.CardEditor.FilterDamageTypes"}}</span><input name="card.filters.damageTypes" value="{{card.filters.damageTypes}}" {{#unless packEditable}}disabled{{/unless}}></label>
                <label><span>{{localize "PF2E_CRITICAL_FORGE.CardEditor.FilterWeaponGroups"}}</span><input name="card.filters.weaponGroups" value="{{card.filters.weaponGroups}}" {{#unless packEditable}}disabled{{/unless}}></label>
                <label><span>{{localize "PF2E_CRITICAL_FORGE.CardEditor.FilterAttackTraits"}}</span><input name="card.filters.attackTraits" value="{{card.filters.attackTraits}}" {{#unless packEditable}}disabled{{/unless}}></label>
                <label><span>{{localize "PF2E_CRITICAL_FORGE.CardEditor.FilterExcludedAttackTraits"}}</span><input name="card.filters.excludedAttackTraits" value="{{card.filters.excludedAttackTraits}}" placeholder="spell" {{#unless packEditable}}disabled{{/unless}}></label>
                <label><span>{{localize "PF2E_CRITICAL_FORGE.CardEditor.FilterSaveTypes"}}</span><input name="card.filters.saveTypes" value="{{card.filters.saveTypes}}" placeholder="fortitude, reflex, will" {{#unless packEditable}}disabled{{/unless}}></label>
                <label><span>{{localize "PF2E_CRITICAL_FORGE.CardEditor.FilterSpellTraditions"}}</span><input name="card.filters.spellTraditions" value="{{card.filters.spellTraditions}}" placeholder="arcane, divine, occult, primal" {{#unless packEditable}}disabled{{/unless}}></label>
                <label><span>{{localize "PF2E_CRITICAL_FORGE.CardEditor.FilterSpellTraits"}}</span><input name="card.filters.spellTraits" value="{{card.filters.spellTraits}}" placeholder="fire, mental, healing" {{#unless packEditable}}disabled{{/unless}}></label>
                <label><span>{{localize "PF2E_CRITICAL_FORGE.CardEditor.FilterSourceTraits"}}</span><input name="card.filters.sourceTraits" value="{{card.filters.sourceTraits}}" {{#unless packEditable}}disabled{{/unless}}></label>
                <label><span>{{localize "PF2E_CRITICAL_FORGE.CardEditor.FilterTargetTraits"}}</span><input name="card.filters.targetTraits" value="{{card.filters.targetTraits}}" {{#unless packEditable}}disabled{{/unless}}></label>
                <label><span>{{localize "PF2E_CRITICAL_FORGE.CardEditor.FilterExcludedSourceTraits"}}</span><input name="card.filters.excludedSourceTraits" value="{{card.filters.excludedSourceTraits}}" {{#unless packEditable}}disabled{{/unless}}></label>
                <label><span>{{localize "PF2E_CRITICAL_FORGE.CardEditor.FilterExcludedTargetTraits"}}</span><input name="card.filters.excludedTargetTraits" value="{{card.filters.excludedTargetTraits}}" {{#unless packEditable}}disabled{{/unless}}></label>
              </div>
            </details>

            <details class="card-editor-details card-editor-condition-panel" open>
              <summary>{{localize "PF2E_CRITICAL_FORGE.CardEditor.Conditions"}}</summary>
              <p class="hint">{{localize "PF2E_CRITICAL_FORGE.CardEditor.ConditionsHint"}}</p>

              {{#if card.conditionEditor.enabled}}
                <div class="card-editor-condition-toolbar">
                  <span class="card-editor-badge editable">{{card.conditionEditor.nodeCount}} {{localize "PF2E_CRITICAL_FORGE.CardEditor.ConditionNodes"}}</span>
                  <button type="button" class="danger" data-action="clearConditions" {{#unless packEditable}}disabled{{/unless}}><i class="fa-solid fa-trash"></i> {{localize "PF2E_CRITICAL_FORGE.CardEditor.ClearConditions"}}</button>
                </div>

                <div class="card-editor-condition-tree">
                  {{#each card.conditionEditor.nodes as |node|}}
                    {{#if node.isGroup}}
                      <div class="card-editor-condition-node group" style="--condition-indent: {{node.indent}}px;">
                        <div class="card-editor-condition-node-main">
                          <i class="fa-solid fa-code-branch"></i>
                          <label>
                            <span>{{localize "PF2E_CRITICAL_FORGE.CardEditor.ConditionGroupMode"}}</span>
                            <select name="condition.{{node.key}}.mode" data-condition-rerender {{#unless @root.packEditable}}disabled{{/unless}}>
                              {{#each node.modeOptions as |option|}}<option value="{{option.value}}" {{#if option.selected}}selected{{/if}}>{{option.label}}</option>{{/each}}
                            </select>
                          </label>
                        </div>
                        <div class="card-editor-condition-node-actions">
                          <button type="button" data-action="addCondition" data-condition-path="{{node.path}}" title="{{localize 'PF2E_CRITICAL_FORGE.CardEditor.AddCondition'}}" {{#unless @root.packEditable}}disabled{{/unless}}><i class="fa-solid fa-plus"></i> {{localize "PF2E_CRITICAL_FORGE.CardEditor.ConditionLeaf"}}</button>
                          <button type="button" data-action="addConditionGroup" data-condition-path="{{node.path}}" title="{{localize 'PF2E_CRITICAL_FORGE.CardEditor.AddConditionGroup'}}" {{#unless @root.packEditable}}disabled{{/unless}}><i class="fa-solid fa-folder-plus"></i> {{localize "PF2E_CRITICAL_FORGE.CardEditor.ConditionGroup"}}</button>
                          <button type="button" class="danger icon" data-action="removeConditionNode" data-condition-path="{{node.path}}" title="{{localize 'PF2E_CRITICAL_FORGE.CardEditor.RemoveConditionNode'}}" {{#unless @root.packEditable}}disabled{{/unless}}><i class="fa-solid fa-xmark"></i></button>
                        </div>
                      </div>
                    {{else}}
                      <div class="card-editor-condition-node leaf" style="--condition-indent: {{node.indent}}px;">
                        <div class="card-editor-condition-leaf-grid">
                          <label>
                            <span>{{localize "PF2E_CRITICAL_FORGE.CardEditor.ConditionField"}}</span>
                            <select name="condition.{{node.key}}.fieldSelection" data-condition-rerender {{#unless @root.packEditable}}disabled{{/unless}}>
                              {{#each node.fieldOptions as |group|}}
                                <optgroup label="{{group.label}}">
                                  {{#each group.options as |option|}}<option value="{{option.value}}" {{#if option.selected}}selected{{/if}}>{{option.label}}</option>{{/each}}
                                </optgroup>
                              {{/each}}
                            </select>
                          </label>
                          {{#if node.isCustomField}}
                            <label>
                              <span>{{localize "PF2E_CRITICAL_FORGE.CardEditor.ConditionCustomField"}}</span>
                              <input name="condition.{{node.key}}.customField" value="{{node.customField}}" placeholder="provider.custom.value" {{#unless @root.packEditable}}disabled{{/unless}}>
                            </label>
                            <label>
                              <span>{{localize "PF2E_CRITICAL_FORGE.CardEditor.ConditionCustomType"}}</span>
                              <select name="condition.{{node.key}}.customType" data-condition-rerender {{#unless @root.packEditable}}disabled{{/unless}}>
                                {{#each node.customTypeOptions as |option|}}<option value="{{option.value}}" {{#if option.selected}}selected{{/if}}>{{option.label}}</option>{{/each}}
                              </select>
                            </label>
                          {{else}}
                            <input type="hidden" name="condition.{{node.key}}.customField" value="">
                            <input type="hidden" name="condition.{{node.key}}.customType" value="{{node.type}}">
                          {{/if}}
                          <label>
                            <span>{{localize "PF2E_CRITICAL_FORGE.CardEditor.ConditionOperator"}}</span>
                            <select name="condition.{{node.key}}.operator" data-condition-rerender {{#unless @root.packEditable}}disabled{{/unless}}>
                              {{#each node.operatorOptions as |option|}}<option value="{{option.value}}" {{#if option.selected}}selected{{/if}}>{{option.label}}</option>{{/each}}
                            </select>
                          </label>
                          {{#if node.requiresValue}}
                            <label>
                              <span>{{localize "PF2E_CRITICAL_FORGE.CardEditor.ConditionValue"}}</span>
                              {{#if node.isEnum}}
                                <select name="condition.{{node.key}}.value" {{#unless @root.packEditable}}disabled{{/unless}}>{{#each node.valueOptions as |option|}}<option value="{{option.value}}" {{#if option.selected}}selected{{/if}}>{{option.label}}</option>{{/each}}</select>
                              {{else}}
                                {{#if node.isBoolean}}
                                  <select name="condition.{{node.key}}.value" {{#unless @root.packEditable}}disabled{{/unless}}>{{#each node.booleanOptions as |option|}}<option value="{{option.value}}" {{#if option.selected}}selected{{/if}}>{{option.label}}</option>{{/each}}</select>
                                {{else}}
                                  {{#if node.isNumber}}
                                    <input type="number" name="condition.{{node.key}}.value" value="{{node.value}}" step="any" {{#unless @root.packEditable}}disabled{{/unless}}>
                                  {{else}}
                                    <input name="condition.{{node.key}}.value" value="{{node.value}}" {{#if node.isArray}}placeholder="trait-a, trait-b"{{/if}} {{#unless @root.packEditable}}disabled{{/unless}}>
                                  {{/if}}
                                {{/if}}
                              {{/if}}
                            </label>
                          {{else}}
                            <div class="card-editor-condition-unary">{{localize "PF2E_CRITICAL_FORGE.CardEditor.ConditionNoValue"}}</div>
                          {{/if}}
                        </div>
                        <button type="button" class="danger icon card-editor-condition-remove" data-action="removeConditionNode" data-condition-path="{{node.path}}" title="{{localize 'PF2E_CRITICAL_FORGE.CardEditor.RemoveConditionNode'}}" {{#unless @root.packEditable}}disabled{{/unless}}><i class="fa-solid fa-xmark"></i></button>
                      </div>
                    {{/if}}
                  {{/each}}
                </div>

                {{#if card.conditionWarnings.length}}
                  <div class="card-editor-condition-warnings">
                    <strong><i class="fa-solid fa-triangle-exclamation"></i> {{localize "PF2E_CRITICAL_FORGE.CardEditor.ConditionWarningsTitle"}}</strong>
                    <ul>{{#each card.conditionWarnings as |warning|}}<li>{{warning.text}}</li>{{/each}}</ul>
                  </div>
                {{/if}}

                <section class="card-editor-condition-test" data-condition-test-panel>
                  <div class="card-editor-section-heading">
                    <div>
                      <h4><i class="fa-solid fa-flask"></i> {{localize "PF2E_CRITICAL_FORGE.CardEditor.ConditionTest"}}</h4>
                      <p>{{localize "PF2E_CRITICAL_FORGE.CardEditor.ConditionTestHint"}}</p>
                    </div>
                    <div class="card-editor-inline-actions">
                      <button type="button" class="primary" data-action="testConditions"><i class="fa-solid fa-play"></i> {{localize "PF2E_CRITICAL_FORGE.CardEditor.RunConditionTest"}}</button>
                      <button type="button" data-action="clearConditionTest" {{#unless card.conditionTest.hasResult}}disabled{{/unless}}><i class="fa-solid fa-eraser"></i> {{localize "PF2E_CRITICAL_FORGE.CardEditor.ClearConditionTest"}}</button>
                    </div>
                  </div>
                  <div class="card-editor-grid condition-test-grid">
                    <label><span>{{localize "PF2E_CRITICAL_FORGE.CardEditor.Category"}}</span><select name="conditionTest.category" data-condition-test-input>{{#each card.conditionTest.categoryOptions as |option|}}<option value="{{option.value}}" {{#if option.selected}}selected{{/if}}>{{option.label}}</option>{{/each}}</select></label>
                    <label><span>{{localize "PF2E_CRITICAL_FORGE.CardEditor.ConditionTestSaveType"}}</span><select name="conditionTest.saveType" data-condition-test-input>{{#each card.conditionTest.saveTypeOptions as |option|}}<option value="{{option.value}}" {{#if option.selected}}selected{{/if}}>{{option.label}}</option>{{/each}}</select></label>
                    <label><span>{{localize "PF2E_CRITICAL_FORGE.CardEditor.ConditionTestSourceLevel"}}</span><input type="number" name="conditionTest.sourceLevel" value="{{card.conditionTest.input.sourceLevel}}" step="1" data-condition-test-input></label>
                    <label><span>{{localize "PF2E_CRITICAL_FORGE.CardEditor.ConditionTestTargetLevel"}}</span><input type="number" name="conditionTest.targetLevel" value="{{card.conditionTest.input.targetLevel}}" step="1" data-condition-test-input></label>
                    <label><span>{{localize "PF2E_CRITICAL_FORGE.CardEditor.ConditionTestSourceHpRatio"}}</span><input type="number" name="conditionTest.sourceHpRatio" value="{{card.conditionTest.input.sourceHpRatio}}" min="0" max="1" step="0.01" data-condition-test-input></label>
                    <label><span>{{localize "PF2E_CRITICAL_FORGE.CardEditor.ConditionTestTargetHpRatio"}}</span><input type="number" name="conditionTest.targetHpRatio" value="{{card.conditionTest.input.targetHpRatio}}" min="0" max="1" step="0.01" data-condition-test-input></label>
                    <label><span>{{localize "PF2E_CRITICAL_FORGE.CardEditor.ConditionTestThreats"}}</span><input type="number" name="conditionTest.hostileThreatCount" value="{{card.conditionTest.input.hostileThreatCount}}" min="0" step="1" data-condition-test-input></label>
                    <label><span>{{localize "PF2E_CRITICAL_FORGE.CardEditor.ConditionTestDc"}}</span><input type="number" name="conditionTest.dc" value="{{card.conditionTest.input.dc}}" step="1" data-condition-test-input></label>
                    <label><span>{{localize "PF2E_CRITICAL_FORGE.CardEditor.ConditionTestSourceTraits"}}</span><input name="conditionTest.sourceTraits" value="{{card.conditionTest.input.sourceTraits}}" placeholder="undead, fire" data-condition-test-input></label>
                    <label><span>{{localize "PF2E_CRITICAL_FORGE.CardEditor.ConditionTestTargetTraits"}}</span><input name="conditionTest.targetTraits" value="{{card.conditionTest.input.targetTraits}}" placeholder="dragon, huge" data-condition-test-input></label>
                    <label><span>{{localize "PF2E_CRITICAL_FORGE.CardEditor.ConditionTestRound"}}</span><input type="number" name="conditionTest.round" value="{{card.conditionTest.input.round}}" min="0" step="1" data-condition-test-input></label>
                    <label><span>{{localize "PF2E_CRITICAL_FORGE.CardEditor.ConditionTestTurn"}}</span><input type="number" name="conditionTest.turn" value="{{card.conditionTest.input.turn}}" min="0" step="1" data-condition-test-input></label>
                  </div>

                  {{#if card.conditionTest.hasResult}}
                    <div class="card-editor-condition-test-result {{#if card.conditionTest.matched}}matched{{else}}failed{{/if}}">
                      <strong><i class="fa-solid {{#if card.conditionTest.matched}}fa-circle-check{{else}}fa-circle-xmark{{/if}}"></i> {{#if card.conditionTest.matched}}{{localize "PF2E_CRITICAL_FORGE.CardEditor.ConditionTestCardAvailable"}}{{else}}{{localize "PF2E_CRITICAL_FORGE.CardEditor.ConditionTestCardUnavailable"}}{{/if}}</strong>
                      <span>{{card.conditionTest.summary}}</span>
                      <div class="card-editor-condition-test-rows">
                        {{#each card.conditionTest.rows as |row|}}
                          <div class="condition-test-row {{row.statusClass}}" style="--condition-indent: {{row.indent}}px;">
                            {{#if row.isGroup}}
                              <code>{{row.mode}}</code><span>{{row.statusLabel}}</span>
                            {{else}}
                              <code>{{row.field}}</code><span>{{row.operatorLabel}} {{row.expectedText}}</span><span>{{localize "PF2E_CRITICAL_FORGE.CardEditor.ConditionActual"}}: {{row.actualText}}</span><strong>{{row.statusLabel}}</strong>
                            {{/if}}
                          </div>
                        {{/each}}
                      </div>
                      <details><summary>{{localize "PF2E_CRITICAL_FORGE.CardEditor.ConditionTestSnapshot"}}</summary><pre>{{card.conditionTest.snapshotJson}}</pre></details>
                    </div>
                  {{/if}}
                </section>
              {{else}}
                <div class="card-editor-condition-empty">
                  <i class="fa-solid fa-filter-circle-xmark"></i>
                  <p>{{localize "PF2E_CRITICAL_FORGE.CardEditor.NoConditions"}}</p>
                  <button type="button" class="primary" data-action="enableConditions" {{#unless packEditable}}disabled{{/unless}}><i class="fa-solid fa-plus"></i> {{localize "PF2E_CRITICAL_FORGE.CardEditor.EnableConditions"}}</button>
                </div>
              {{/if}}
            </details>

            <section class="card-editor-effect-panel {{#if card.effect}}has-effect{{/if}}">
              <div class="card-editor-section-heading">
                <div>
                  <h4><i class="fa-solid fa-bolt"></i> {{localize "PF2E_CRITICAL_FORGE.CardEditor.MechanicalEffect"}}</h4>
                  <p>{{card.effectSummary}}</p>
                </div>
                <div class="card-editor-inline-actions">
                  <button type="button" class="primary" data-action="editEffect" {{#unless packEditable}}disabled{{/unless}}><i class="fa-solid fa-hammer"></i> {{localize "PF2E_CRITICAL_FORGE.CardEditor.EditInEffectForge"}}</button>
                  <button type="button" data-action="clearEffect" {{#unless card.effect}}disabled{{/unless}} {{#unless packEditable}}disabled{{/unless}}><i class="fa-solid fa-eraser"></i> {{localize "PF2E_CRITICAL_FORGE.CardEditor.RemoveEffect"}}</button>
                </div>
              </div>
              <div class="card-editor-target-map">
                <span><strong>{{localize "PF2E_CRITICAL_FORGE.CardEditor.EffectTargets.Source"}}:</strong> {{localize "PF2E_CRITICAL_FORGE.CardEditor.EffectTargetSourceHint"}}</span>
                <span><strong>{{localize "PF2E_CRITICAL_FORGE.CardEditor.EffectTargets.Target"}}:</strong> {{localize "PF2E_CRITICAL_FORGE.CardEditor.EffectTargetTargetHint"}}</span>
              </div>
              {{#if card.effect}}
                <div class="card-editor-grid effect-meta-grid">
                  <label><span>{{localize "PF2E_CRITICAL_FORGE.CardEditor.EffectTarget"}}</span><select name="card.effect.target" {{#unless packEditable}}disabled{{/unless}}>{{#each card.effectTargetOptions as |option|}}<option value="{{option.value}}" {{#if option.selected}}selected{{/if}}>{{option.label}}</option>{{/each}}</select></label>
                  <label><span>{{localize "PF2E_CRITICAL_FORGE.CardEditor.EffectFallbackName"}}</span><input name="card.effect.fallbackName" value="{{card.effectFallbackName}}" {{#unless packEditable}}disabled{{/unless}}></label>
                  <label class="wide advanced"><span>{{localize "PF2E_CRITICAL_FORGE.CardEditor.EffectNameKey"}}</span><input name="card.effect.nameKey" value="{{card.effectNameKey}}" {{#unless packEditable}}disabled{{/unless}}></label>
                </div>
              {{/if}}
            </section>
          </section>
        {{else}}
          <div class="card-editor-empty workspace-empty">
            <i class="fa-solid fa-clone"></i>
            <p>{{localize "PF2E_CRITICAL_FORGE.CardEditor.SelectOrCreateCard"}}</p>
          </div>
        {{/if}}

        {{#if validation}}
          <section class="card-editor-validation {{#if validation.valid}}valid{{else}}invalid{{/if}}">
            <strong><i class="fa-solid {{#if validation.valid}}fa-circle-check{{else}}fa-triangle-exclamation{{/if}}"></i> {{#if validation.valid}}{{localize "PF2E_CRITICAL_FORGE.CardEditor.ValidPack"}}{{else}}{{localize "PF2E_CRITICAL_FORGE.CardEditor.InvalidPack"}}{{/if}}</strong>
            {{#if validation.count}}
              <ul>{{#each validation.issues as |issue|}}<li class="{{issue.severity}}">{{issue.text}}</li>{{/each}}</ul>
            {{/if}}
          </section>
        {{/if}}
      {{else}}
        <div class="card-editor-empty workspace-empty"><p>{{localize "PF2E_CRITICAL_FORGE.CardEditor.NoPack"}}</p></div>
      {{/if}}
    </section>
  </main>

  <footer class="card-editor-footer">
    <button type="button" class="primary" data-action="savePack" {{#unless canSave}}disabled{{/unless}}><i class="fa-solid fa-floppy-disk"></i> {{localize "PF2E_CRITICAL_FORGE.CardEditor.SavePack"}}</button>
    <button type="button" class="danger" data-action="deletePack" {{#unless canDeletePack}}disabled{{/unless}}><i class="fa-solid fa-trash"></i> {{localize "PF2E_CRITICAL_FORGE.CardEditor.DeletePack"}}</button>
    <span class="spacer"></span>
    <button type="button" data-action="closeWindow"><i class="fa-solid fa-xmark"></i> {{localize "PF2E_CRITICAL_FORGE.CardEditor.Close"}}</button>
  </footer>
</div>
