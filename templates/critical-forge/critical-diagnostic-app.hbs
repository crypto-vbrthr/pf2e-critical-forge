<div class="critical-diagnostic-shell">
  <section class="critical-diagnostic-toolbar effect-forge-panel">
    <div class="critical-diagnostic-toolbar-main">
      <label class="effect-forge-field critical-diagnostic-message-select">
        <span>{{localize "PF2E_CRITICAL_FORGE.CriticalDiagnostic.ChatMessage"}}</span>
        <select name="messageId" {{#unless hasMessages}}disabled{{/unless}}>
          {{#unless hasMessages}}
            <option value="">{{localize "PF2E_CRITICAL_FORGE.CriticalDiagnostic.NoMessages"}}</option>
          {{/unless}}
          {{#each messages}}
            <option value="{{id}}" {{#if selected}}selected{{/if}}>{{label}}</option>
          {{/each}}
        </select>
      </label>

      <div class="critical-diagnostic-toolbar-actions">
        <button type="button" class="primary" data-action="analyzeSelected" {{#unless hasMessages}}disabled{{/unless}}>
          <i class="fa-solid fa-magnifying-glass-chart"></i>
          {{localize "PF2E_CRITICAL_FORGE.CriticalDiagnostic.Analyze"}}
        </button>
        <button type="button" data-action="analyzeLatest" {{#unless hasMessages}}disabled{{/unless}}>
          <i class="fa-solid fa-clock-rotate-left"></i>
          {{localize "PF2E_CRITICAL_FORGE.CriticalDiagnostic.AnalyzeLatest"}}
        </button>
        <button type="button" data-action="clearReport" {{#unless hasReport}}disabled{{/unless}}>
          <i class="fa-solid fa-eraser"></i>
          {{localize "PF2E_CRITICAL_FORGE.CriticalDiagnostic.Clear"}}
        </button>
        <button type="button" data-action="replaySnapshot" {{#unless hasReport}}disabled{{/unless}}>
          <i class="fa-solid fa-camera-rotate"></i>
          {{localize "PF2E_CRITICAL_FORGE.CriticalDiagnostic.ReplaySnapshot"}}
        </button>
        <button type="button" data-action="replayCurrent" {{#unless report.canReplayCurrent}}disabled{{/unless}}>
          <i class="fa-solid fa-arrows-rotate"></i>
          {{localize "PF2E_CRITICAL_FORGE.CriticalDiagnostic.ReplayCurrent"}}
        </button>
      </div>
    </div>

    <div class="critical-diagnostic-drop-zone" data-chat-message-drop-zone>
      <i class="fa-solid fa-comment-dots"></i>
      <div>
        <strong>{{localize "PF2E_CRITICAL_FORGE.CriticalDiagnostic.DropMessageHere"}}</strong>
        <small>{{localize "PF2E_CRITICAL_FORGE.CriticalDiagnostic.DropMessageHint"}}</small>
      </div>
    </div>

    <div class="critical-diagnostic-target-state">
      <i class="fa-solid fa-crosshairs"></i>
      <span>{{localize targetStatusKey}}</span>
      {{#if targetNames}}<strong>{{targetNames}}</strong>{{/if}}
      <span class="critical-diagnostic-build">
        <i class="fa-solid fa-cubes-stacked"></i>
        {{localize "PF2E_CRITICAL_FORGE.CriticalDiagnostic.DiagnosticsPhase"}} · {{moduleVersion}}
      </span>
    </div>
  </section>

  {{#if hasReport}}
    <div class="critical-diagnostic-workspace">
      <main class="critical-diagnostic-column">
        <section class="effect-forge-panel critical-diagnostic-summary">
          <header class="critical-diagnostic-section-header">
            <h2>{{localize "PF2E_CRITICAL_FORGE.CriticalDiagnostic.ContextSummary"}}</h2>
            <span class="critical-diagnostic-status {{report.statusClass}}">
              <i class="fa-solid {{report.statusIcon}}"></i>
              {{report.statusText}}
            </span>
          </header>

          <div class="critical-diagnostic-facts">
            <div>
              <span>{{localize "PF2E_CRITICAL_FORGE.CriticalDiagnostic.Category"}}</span>
              <strong>{{report.category}}</strong>
            </div>
            <div>
              <span>{{localize "PF2E_CRITICAL_FORGE.CriticalDiagnostic.Outcome"}}</span>
              <strong>{{report.outcome}}</strong>
            </div>
            <div>
              <span>{{localize "PF2E_CRITICAL_FORGE.CriticalDiagnostic.EligibleCards"}}</span>
              <strong>{{report.eligibleCount}}</strong>
            </div>
            <div>
              <span>{{localize "PF2E_CRITICAL_FORGE.CriticalDiagnostic.RequestedDeck"}}</span>
              <strong>{{report.requestedDeckLabel}}</strong>
            </div>
            <div>
              <span>{{localize "PF2E_CRITICAL_FORGE.CriticalDiagnostic.TotalWeight"}}</span>
              <strong>{{report.totalWeight}}</strong>
            </div>
            <div>
              <span>{{localize "PF2E_CRITICAL_FORGE.CriticalDiagnostic.TriggerBehavior"}}</span>
              <strong>{{report.triggerAction}}</strong>
            </div>
            <div>
              <span>{{localize "PF2E_CRITICAL_FORGE.CriticalDiagnostic.TriggerScope"}}</span>
              <strong>{{report.triggerScope}}</strong>
            </div>
            <div>
              <span>{{localize "PF2E_CRITICAL_FORGE.CriticalDiagnostic.TriggerResult"}}</span>
              <strong>{{report.triggerMatched}}</strong>
            </div>
          </div>

          <div class="critical-diagnostic-tag-groups">
            <div class="critical-diagnostic-tag-group">
              <h3>{{localize "PF2E_CRITICAL_FORGE.CriticalDiagnostic.DamageTypes"}}</h3>
              <div class="critical-diagnostic-tags">
                {{#each report.damageTypes}}<span>{{this}}</span>{{else}}<em>—</em>{{/each}}
              </div>
            </div>
            <div class="critical-diagnostic-tag-group">
              <h3>{{localize "PF2E_CRITICAL_FORGE.CriticalDiagnostic.WeaponGroups"}}</h3>
              <div class="critical-diagnostic-tags">
                {{#each report.weaponGroups}}<span>{{this}}</span>{{else}}<em>—</em>{{/each}}
              </div>
            </div>
            <div class="critical-diagnostic-tag-group">
              <h3>{{localize "PF2E_CRITICAL_FORGE.CriticalDiagnostic.AttackTraits"}}</h3>
              <div class="critical-diagnostic-tags">
                {{#each report.attackTraits}}<span>{{this}}</span>{{else}}<em>—</em>{{/each}}
              </div>
            </div>
            <div class="critical-diagnostic-tag-group">
              <h3>{{localize "PF2E_CRITICAL_FORGE.CriticalDiagnostic.SaveTypes"}}</h3>
              <div class="critical-diagnostic-tags">
                {{#each report.saveTypes}}<span>{{this}}</span>{{else}}<em>—</em>{{/each}}
              </div>
            </div>
            <div class="critical-diagnostic-tag-group">
              <h3>{{localize "PF2E_CRITICAL_FORGE.CriticalDiagnostic.SpellTraditions"}}</h3>
              <div class="critical-diagnostic-tags">
                {{#each report.spellTraditions}}<span>{{this}}</span>{{else}}<em>—</em>{{/each}}
              </div>
            </div>
            <div class="critical-diagnostic-tag-group">
              <h3>{{localize "PF2E_CRITICAL_FORGE.CriticalDiagnostic.SpellTraits"}}</h3>
              <div class="critical-diagnostic-tags">
                {{#each report.spellTraits}}<span>{{this}}</span>{{else}}<em>—</em>{{/each}}
              </div>
            </div>
            <div class="critical-diagnostic-tag-group">
              <h3>{{localize "PF2E_CRITICAL_FORGE.CriticalDiagnostic.SourceTraits"}}</h3>
              <div class="critical-diagnostic-tags">
                {{#each report.sourceTraits}}<span>{{this}}</span>{{else}}<em>—</em>{{/each}}
              </div>
            </div>
            <div class="critical-diagnostic-tag-group">
              <h3>{{localize "PF2E_CRITICAL_FORGE.CriticalDiagnostic.TargetTraits"}}</h3>
              <div class="critical-diagnostic-tags">
                {{#each report.targetTraits}}<span>{{this}}</span>{{else}}<em>—</em>{{/each}}
              </div>
            </div>
          </div>
        </section>

        <section class="effect-forge-panel critical-diagnostic-phases">
          <header class="critical-diagnostic-section-header">
            <h2>{{localize "PF2E_CRITICAL_FORGE.CriticalDiagnostic.Pipeline"}}</h2>
            <span class="critical-diagnostic-context-schema">v{{report.reportVersion}} · {{report.originLabel}} · {{report.createdAt}}</span>
          </header>
          <div class="critical-diagnostic-phase-grid">
            <div><i class="fa-solid fa-magnifying-glass"></i><span>{{localize "PF2E_CRITICAL_FORGE.CriticalDiagnostic.PhaseContext"}}</span><strong>{{report.contextPhaseStatus}}</strong></div>
            <div><i class="fa-solid fa-shuffle"></i><span>{{localize "PF2E_CRITICAL_FORGE.CriticalDiagnostic.PhaseSelection"}}</span><strong>{{report.selectionPhaseStatus}}</strong><small>{{report.selectedCard}}</small></div>
            <div><i class="fa-solid fa-wand-magic-sparkles"></i><span>{{localize "PF2E_CRITICAL_FORGE.CriticalDiagnostic.PhaseApplication"}}</span><strong>{{report.applicationPhaseStatus}}</strong></div>
          </div>
        </section>

        <section class="effect-forge-panel critical-diagnostic-runtime">
          <header class="critical-diagnostic-section-header">
            <h2>{{localize "PF2E_CRITICAL_FORGE.CriticalDiagnostic.RuntimeContext"}}</h2>
            <span class="critical-diagnostic-context-schema">
              {{localize "PF2E_CRITICAL_FORGE.CriticalDiagnostic.SnapshotSchema"}} {{report.snapshotVersion}}
            </span>
          </header>

          {{#if report.hasSnapshot}}
            <div class="critical-diagnostic-facts">
              <div>
                <span>{{localize "PF2E_CRITICAL_FORGE.CriticalDiagnostic.ContextProvider"}}</span>
                <strong>{{report.snapshotProvider}}</strong>
              </div>
              <div>
                <span>{{localize "PF2E_CRITICAL_FORGE.CriticalDiagnostic.RollFamily"}}</span>
                <strong>{{report.rollFamily}}</strong>
              </div>
              <div>
                <span>{{localize "PF2E_CRITICAL_FORGE.CriticalDiagnostic.SaveType"}}</span>
                <strong>{{report.saveType}}</strong>
              </div>
              <div>
                <span>{{localize "PF2E_CRITICAL_FORGE.CriticalDiagnostic.Roller"}}</span>
                <strong>{{report.rollerName}}</strong>
              </div>
              <div>
                <span>{{localize "PF2E_CRITICAL_FORGE.CriticalDiagnostic.ActorLevel"}}</span>
                <strong>{{report.rollerLevel}}</strong>
              </div>
              <div>
                <span>{{localize "PF2E_CRITICAL_FORGE.CriticalDiagnostic.HitPoints"}}</span>
                <strong>{{report.rollerHp}} · {{report.rollerHpRatio}}</strong>
              </div>
              <div>
                <span>{{localize "PF2E_CRITICAL_FORGE.CriticalDiagnostic.Opponent"}}</span>
                <strong>{{report.opponentName}} · {{report.opponentLevel}}</strong>
              </div>
              <div>
                <span>{{localize "PF2E_CRITICAL_FORGE.CriticalDiagnostic.HostileThreats"}}</span>
                <strong>{{report.hostileThreatCount}} · {{report.threatEvaluation}}</strong>
              </div>
            </div>

            {{#if report.hasHostileThreatDetails}}
              <div class="critical-diagnostic-threats">
                <header class="critical-diagnostic-threats-header">
                  <h3>{{localize "PF2E_CRITICAL_FORGE.CriticalDiagnostic.ThreatDetails"}}</h3>
                  <span>{{localize "PF2E_CRITICAL_FORGE.CriticalDiagnostic.ThreatSummary" candidates=report.threatCandidateCount counted=report.threatCountedCount rejected=report.threatRejectedCount}}</span>
                </header>
                <div class="critical-diagnostic-threat-list">
                  {{#each report.hostileThreats}}
                    <details class="critical-diagnostic-threat-entry {{statusClass}}" {{#if counted}}open{{/if}}>
                      <summary>
                        <strong>{{name}}</strong>
                        <span class="critical-diagnostic-status {{statusClass}}">{{localize statusKey}}</span>
                      </summary>
                      <div class="critical-diagnostic-threat-facts">
                        <div><span>{{localize "PF2E_CRITICAL_FORGE.CriticalDiagnostic.ThreatAlliance"}}</span><strong>{{alliance}}</strong></div>
                        <div><span>{{localize "PF2E_CRITICAL_FORGE.CriticalDiagnostic.ThreatPerception"}}</span><strong>{{localize perceptionKey}}</strong><small>{{perceptionSource}}</small></div>
                        <div><span>{{localize "PF2E_CRITICAL_FORGE.CriticalDiagnostic.ThreatDistance"}}</span><strong>{{distance}}</strong></div>
                        <div><span>{{localize "PF2E_CRITICAL_FORGE.CriticalDiagnostic.ThreatAttack"}}</span><strong>{{attackName}}</strong><small>{{attackReach}}</small></div>
                        <div><span>{{localize "PF2E_CRITICAL_FORGE.CriticalDiagnostic.ThreatLineOfSight"}}</span><strong>{{localize lineOfSightKey}}</strong><small>{{lineOfSightMethod}}</small></div>
                      </div>
                      {{#if hasRejections}}
                        <div class="critical-diagnostic-threat-reasons">
                          <strong>{{localize "PF2E_CRITICAL_FORGE.CriticalDiagnostic.ThreatReasons"}}</strong>
                          <ul>{{#each rejectionKeys}}<li>{{localize this}}</li>{{/each}}</ul>
                        </div>
                      {{/if}}
                    </details>
                  {{/each}}
                </div>
              </div>
            {{/if}}
          {{else}}
            <p class="critical-diagnostic-empty">{{localize "PF2E_CRITICAL_FORGE.CriticalDiagnostic.NoRuntimeContext"}}</p>
          {{/if}}
        </section>

        {{#if report.hasExtensionDiagnostics}}
          <section class="effect-forge-panel critical-diagnostic-extension-providers">
            <header class="critical-diagnostic-section-header">
              <h2>{{localize "PF2E_CRITICAL_FORGE.CriticalDiagnostic.ExtensionDiagnostics"}}</h2>
              <span class="critical-diagnostic-context-schema">{{report.extensionDiagnostics.length}}</span>
            </header>
            <div class="critical-diagnostic-extension-list">
              {{#each report.extensionDiagnostics}}
                <details class="critical-diagnostic-extension-entry">
                  <summary>
                    <strong>{{label}}</strong>
                    <span class="critical-diagnostic-status {{statusClass}}">{{statusLabel}}</span>
                  </summary>
                  {{#if errorMessage}}<p class="critical-diagnostic-empty">{{errorMessage}}</p>{{/if}}
                  {{#if dataJson}}<pre>{{dataJson}}</pre>{{/if}}
                </details>
              {{/each}}
            </div>
          </section>
        {{/if}}

        {{#if report.hasReplay}}
          <section class="effect-forge-panel critical-diagnostic-replay">
            <header class="critical-diagnostic-section-header">
              <h2>{{localize "PF2E_CRITICAL_FORGE.CriticalDiagnostic.ReplayResult"}}</h2>
              <span class="critical-diagnostic-status {{report.replay.statusClass}}">{{report.replay.statusText}}</span>
            </header>
            <p><strong>{{report.replay.modeLabel}}</strong></p>
            {{#if report.replay.changes.length}}
              <div class="critical-diagnostic-change-list">
                {{#each report.replay.changes}}
                  <div><code>{{field}}</code><span>{{before}}</span><i class="fa-solid fa-arrow-right"></i><span>{{after}}</span></div>
                {{/each}}
              </div>
            {{/if}}
          </section>
        {{/if}}

        {{#if report.hasActualApplication}}
          <section class="effect-forge-panel critical-diagnostic-application-audit">
            <header class="critical-diagnostic-section-header">
              <h2>{{localize "PF2E_CRITICAL_FORGE.CriticalDiagnostic.ApplicationAudit"}}</h2>
              <span class="critical-diagnostic-status {{report.actualApplication.statusClass}}">{{report.actualApplication.statusLabel}}</span>
            </header>
            <div class="critical-diagnostic-facts">
              <div><span>{{localize "PF2E_CRITICAL_FORGE.CriticalDiagnostic.ApplicationTarget"}}</span><strong>{{report.actualApplication.targetLabel}}</strong></div>
              <div><span>{{localize "PF2E_CRITICAL_FORGE.CriticalDiagnostic.AppliedBy"}}</span><strong>{{report.actualApplication.appliedByLabel}}</strong></div>
              <div><span>{{localize "PF2E_CRITICAL_FORGE.CriticalDiagnostic.AppliedAt"}}</span><strong>{{report.actualApplication.appliedAtLabel}}</strong></div>
              <div><span>{{localize "PF2E_CRITICAL_FORGE.CriticalDiagnostic.ApplicationCode"}}</span><strong>{{report.actualApplication.code}}</strong></div>
            </div>
            {{#if report.actualApplication.hasEffectIds}}
              <div class="critical-diagnostic-simulation-components">
                {{#each report.actualApplication.effectIds}}<span><code>{{this}}</code></span>{{/each}}
              </div>
            {{/if}}
          </section>
        {{/if}}

        {{#if report.hasSimulation}}
          <section class="effect-forge-panel critical-diagnostic-simulation">
            <header class="critical-diagnostic-section-header">
              <h2>{{localize "PF2E_CRITICAL_FORGE.CriticalDiagnostic.Simulation"}}</h2>
              <span class="critical-diagnostic-status {{#if report.simulation.valid}}valid{{else}}invalid{{/if}}">{{report.simulation.statusLabel}}</span>
            </header>
            <div class="critical-diagnostic-facts">
              <div><span>{{localize "PF2E_CRITICAL_FORGE.CriticalDiagnostic.SimulatedCard"}}</span><strong>{{report.simulation.cardId}}</strong></div>
              <div><span>{{localize "PF2E_CRITICAL_FORGE.CriticalDiagnostic.SimulationTarget"}}</span><strong>{{report.simulation.targetLabel}}</strong></div>
              <div><span>{{localize "PF2E_CRITICAL_FORGE.CriticalDiagnostic.Duration"}}</span><strong>{{report.simulation.duration}}</strong></div>
              <div><span>{{localize "PF2E_CRITICAL_FORGE.CriticalDiagnostic.DocumentsChanged"}}</span><strong>{{localize "PF2E_CRITICAL_FORGE.CriticalDiagnostic.No"}}</strong></div>
            </div>
            {{#if report.simulation.hasComponents}}
              <div class="critical-diagnostic-simulation-components">
                {{#each report.simulation.components}}<span><strong>{{type}}:</strong> {{summary}}</span>{{/each}}
              </div>
            {{/if}}
            {{#if report.simulation.code}}<p class="critical-diagnostic-empty"><code>{{report.simulation.code}}</code></p>{{/if}}
          </section>
        {{/if}}

        <section class="effect-forge-panel critical-diagnostic-candidates">
          <header class="critical-diagnostic-section-header">
            <h2>{{localize "PF2E_CRITICAL_FORGE.CriticalDiagnostic.EligibleCards"}} ({{report.eligibleCount}})</h2>
            <span class="critical-diagnostic-profile">{{localize "PF2E_CRITICAL_FORGE.CriticalDiagnostic.CardProfile"}}: {{report.profileLabel}}</span>
          </header>

          {{#if report.hasEligible}}
            <div class="critical-diagnostic-card-list">
              {{#each report.eligible}}
                <article class="critical-diagnostic-card eligible">
                  <header>
                    <div>
                      <strong>{{title}}</strong>
                      <code>{{id}}</code>
                    </div>
                    <span class="critical-diagnostic-weight" title="{{localize 'PF2E_CRITICAL_FORGE.CriticalDiagnostic.EffectiveWeight'}}">
                      {{effectiveWeight}}
                    </span>
                  </header>
                  <p>{{description}}</p>
                  <div class="critical-diagnostic-card-meta">
                    <span>{{localize "PF2E_CRITICAL_FORGE.CriticalDiagnostic.Specificity"}}: {{specificity}}</span>
                    <span>{{localize "PF2E_CRITICAL_FORGE.CriticalDiagnostic.BaseWeight"}}: {{baseWeight}}</span>
                    <span>{{localize "PF2E_CRITICAL_FORGE.CriticalDiagnostic.ProfileMultiplier"}}: {{profileMultiplier}}</span>
                    <span>{{localize "PF2E_CRITICAL_FORGE.CriticalDiagnostic.Tone"}}: {{toneLabel}}</span>
                    <span>{{localize "PF2E_CRITICAL_FORGE.CriticalDiagnostic.Impact"}}: {{impactLabel}}</span>
                    <span>{{localize "PF2E_CRITICAL_FORGE.CriticalDiagnostic.Deck"}}: {{deckLabel}}</span>
                  </div>
                  {{#if hasMatches}}
                    <div class="critical-diagnostic-match-list">
                      {{#each matchedFilters}}
                        <span><strong>{{label}}:</strong> {{values}}</span>
                      {{/each}}
                    </div>
                  {{/if}}
                  {{#if hasConditions}}
                    <div class="critical-diagnostic-condition-evaluation">
                      <strong>{{localize "PF2E_CRITICAL_FORGE.CriticalDiagnostic.ContextConditions"}}</strong>
                      {{#each conditionEvaluation.rows}}
                        <span class="{{statusClass}}">
                          <i class="fa-solid {{icon}}"></i>
                          <code>{{field}}</code> {{operatorLabel}} <strong>{{expected}}</strong>
                          <em>{{localize "PF2E_CRITICAL_FORGE.CriticalDiagnostic.ActualValue"}}: {{actual}}</em>
                        </span>
                      {{/each}}
                    </div>
                  {{/if}}
                  <div class="critical-diagnostic-card-actions">
                    <button type="button" class="primary" data-action="previewCard" data-card-id="{{id}}">
                      <i class="fa-solid fa-comment-medical"></i>
                      {{localize "PF2E_CRITICAL_FORGE.CriticalPreview.ShowInChat"}}
                    </button>
                    <button type="button" data-action="simulateCard" data-card-id="{{id}}">
                      <i class="fa-solid fa-flask-vial"></i>
                      {{localize "PF2E_CRITICAL_FORGE.CriticalDiagnostic.Simulate"}}
                    </button>
                  </div>
                </article>
              {{/each}}
            </div>
          {{else}}
            <p class="critical-diagnostic-empty">{{localize "PF2E_CRITICAL_FORGE.CriticalDiagnostic.NoEligibleCards"}}</p>
          {{/if}}
        </section>

        <section class="effect-forge-panel critical-diagnostic-candidates rejected-section">
          <header class="critical-diagnostic-section-header">
            <h2>{{localize "PF2E_CRITICAL_FORGE.CriticalDiagnostic.RejectedCards"}} ({{report.rejectedCount}})</h2>
          </header>

          {{#if report.hasRejected}}
            <div class="critical-diagnostic-card-list">
              {{#each report.rejected}}
                <article class="critical-diagnostic-card rejected">
                  <header>
                    <div>
                      <strong>{{title}}</strong>
                      <code>{{id}}</code>
                    </div>
                  </header>
                  <div class="critical-diagnostic-card-meta">
                    <span>{{localize "PF2E_CRITICAL_FORGE.CriticalDiagnostic.Deck"}}: {{deckLabel}}</span>
                    <span>{{localize "PF2E_CRITICAL_FORGE.CriticalDiagnostic.ActiveDeck"}}: {{activeDeckLabel}}</span>
                  </div>
                  <div class="critical-diagnostic-reasons">
                    {{#each rejectedReasons}}<span>{{this}}</span>{{/each}}
                  </div>
                  {{#if hasConditions}}
                    <div class="critical-diagnostic-condition-evaluation">
                      <strong>{{localize "PF2E_CRITICAL_FORGE.CriticalDiagnostic.ContextConditions"}}</strong>
                      {{#each conditionEvaluation.rows}}
                        <span class="{{statusClass}}">
                          <i class="fa-solid {{icon}}"></i>
                          <code>{{field}}</code> {{operatorLabel}} <strong>{{expected}}</strong>
                          <em>{{localize "PF2E_CRITICAL_FORGE.CriticalDiagnostic.ActualValue"}}: {{actual}}</em>
                        </span>
                      {{/each}}
                    </div>
                  {{/if}}
                </article>
              {{/each}}
            </div>
          {{else}}
            <p class="critical-diagnostic-empty">{{localize "PF2E_CRITICAL_FORGE.CriticalDiagnostic.NoRejectedCards"}}</p>
          {{/if}}
        </section>
      </main>

      <aside class="critical-diagnostic-column">
        <section class="effect-forge-panel critical-diagnostic-history">
          <header class="critical-diagnostic-section-header">
            <h2>{{localize "PF2E_CRITICAL_FORGE.CriticalDiagnostic.History"}} ({{historyCount}})</h2>
            <button type="button" data-action="clearHistory" {{#unless hasHistory}}disabled{{/unless}}>
              <i class="fa-solid fa-trash-can"></i>
              {{localize "PF2E_CRITICAL_FORGE.CriticalDiagnostic.ClearHistory"}}
            </button>
          </header>
          {{#if hasHistory}}
            <div class="critical-diagnostic-history-list">
              {{#each history}}
                <button type="button" class="critical-diagnostic-history-entry {{#if selected}}selected{{/if}}" data-action="loadHistory" data-report-id="{{id}}">
                  <span class="critical-diagnostic-history-dot {{statusClass}}"></span>
                  <span><strong>{{label}}</strong><small>{{time}} · {{origin}} · {{eligibleCount}} {{localize "PF2E_CRITICAL_FORGE.CriticalDiagnostic.EligibleShort"}}</small>{{#if selectedCard}}<em>{{selectedCard}}</em>{{/if}}</span>
                </button>
              {{/each}}
            </div>
          {{else}}
            <p class="critical-diagnostic-empty">{{localize "PF2E_CRITICAL_FORGE.CriticalDiagnostic.NoHistory"}}</p>
          {{/if}}
        </section>
        <section class="effect-forge-panel critical-diagnostic-diagnostics">
          <header class="critical-diagnostic-section-header">
            <h2>{{localize "PF2E_CRITICAL_FORGE.CriticalDiagnostic.Diagnostics"}}</h2>
          </header>
          {{#if report.hasDiagnostics}}
            <div class="critical-diagnostic-issue-list">
              {{#each report.diagnostics}}
                <div class="critical-diagnostic-issue {{severity}}">
                  <i class="fa-solid {{icon}}"></i>
                  <div>
                    <strong>{{code}}</strong>
                    <span>{{text}}</span>
                  </div>
                </div>
              {{/each}}
            </div>
          {{else}}
            <p class="critical-diagnostic-empty">{{localize "PF2E_CRITICAL_FORGE.CriticalDiagnostic.NoDiagnostics"}}</p>
          {{/if}}
        </section>

        <section class="effect-forge-panel critical-diagnostic-json">
          <header class="critical-diagnostic-section-header">
            <h2>{{localize "PF2E_CRITICAL_FORGE.CriticalDiagnostic.SelectionContext"}}</h2>
          </header>
          <pre>{{report.contextJson}}</pre>
        </section>

        <section class="effect-forge-panel critical-diagnostic-json">
          <header class="critical-diagnostic-section-header">
            <h2>{{localize "PF2E_CRITICAL_FORGE.CriticalDiagnostic.RuntimeSnapshot"}}</h2>
          </header>
          <pre>{{report.snapshotJson}}</pre>
        </section>

        <section class="effect-forge-panel critical-diagnostic-json">
          <header class="critical-diagnostic-section-header">
            <h2>{{localize "PF2E_CRITICAL_FORGE.CriticalDiagnostic.AdapterMetadata"}}</h2>
          </header>
          <pre>{{report.metadataJson}}</pre>
        </section>
      </aside>
    </div>
  {{else}}
    <section class="effect-forge-panel critical-diagnostic-welcome">
      <i class="fa-solid fa-microscope"></i>
      <h2>{{localize "PF2E_CRITICAL_FORGE.CriticalDiagnostic.WelcomeTitle"}}</h2>
      <p>{{localize "PF2E_CRITICAL_FORGE.CriticalDiagnostic.WelcomeText"}}</p>
      <p class="critical-diagnostic-safety-note">
        <i class="fa-solid fa-shield-halved"></i>
        {{localize "PF2E_CRITICAL_FORGE.CriticalDiagnostic.NoAutomationNotice"}}
      </p>
    </section>
  {{/if}}

  <footer class="critical-diagnostic-footer">
    <button type="button" data-action="copyReport" {{#unless hasReport}}disabled{{/unless}}>
      <i class="fa-regular fa-copy"></i>
      {{localize "PF2E_CRITICAL_FORGE.CriticalDiagnostic.CopyReport"}}
    </button>
    <button type="button" data-action="exportReport" {{#unless hasReport}}disabled{{/unless}}>
      <i class="fa-solid fa-file-export"></i>
      {{localize "PF2E_CRITICAL_FORGE.CriticalDiagnostic.ExportReport"}}
    </button>
    <button type="button" data-action="closeWindow">
      <i class="fa-solid fa-xmark"></i>
      {{localize "PF2E_CRITICAL_FORGE.CriticalDiagnostic.Close"}}
    </button>
  </footer>
</div>
